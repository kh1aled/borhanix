@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["PageTitle"] = $"{Model.Role} dashboard";
}

<!-- Page header -->
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Dashboard</h1>
    <nav class="text-sm">
        <span class="text-blue-500 font-medium cursor-default">Dashboard</span>
        <span class="mx-1.5 text-gray-400 dark:text-gray-600">/</span>
        <span class="text-gray-500 dark:text-gray-400">@Model.Role dashboard</span>
    </nav>
</div>

<!-- Stats grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
    @foreach (var stat in Model.Stats)
    {
        <div class="
            bg-white dark:bg-[#1e2433]
            border border-gray-100 dark:border-[#2a3147]
            rounded-xl
            flex items-center justify-between
            px-6 py-5
            shadow-sm dark:shadow-none
            transition-colors
            ">
            <div class="min-w-0">
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-1 truncate">@stat.Label</p>
                <h3 class="text-3xl font-bold text-gray-900 dark:text-white">@stat.Value</h3>
            </div>
            <div class="w-16 h-16 rounded-full bg-gray-100 dark:bg-[#252d40] flex items-center justify-center shrink-0 ml-4">
                <i data-lucide="@stat.Icon" class="text-blue-500 dark:text-blue-400 w-7 h-7"></i>
            </div>
        </div>
    }
</div>

<!-- Courses + Activity -->
<div class="grid grid-cols-1 xl:grid-cols-[1fr_320px] gap-6">

<!-- Courses -->
    <div>
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-base font-semibold text-gray-700 dark:text-gray-200">Courses</h2>
            <a asp-controller="Courses" asp-action="Index"
               class="text-sm text-blue-500 hover:text-blue-400 font-medium transition-colors">View all</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            @foreach (var course in Model.Courses.Take(6))
            {
                <a asp-controller="Courses" asp-action="Details" asp-route-id="@course.Id"
                   class="
                    block
                    bg-white dark:bg-[#1e2433]
                    border border-gray-100 dark:border-[#2a3147]
                    rounded-xl p-5
                    hover:shadow-md dark:hover:border-blue-500/40
                    transition-all duration-200
                    "
                   style="border-top: 3px solid @course.AccentColor">
                    <span class="text-[11px] font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">@course.Code</span>
                    <h3 class="text-sm font-semibold text-gray-900 dark:text-white mt-1.5 mb-1 line-clamp-2 leading-snug">@course.Title</h3>
                    <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-2 mb-4 leading-relaxed">@course.Summary</p>
                    <div class="flex gap-3 text-xs text-gray-400 dark:text-gray-500">
                        <span class="flex items-center gap-1">
                            <i data-lucide="layers" class="w-3 h-3"></i>
                            @course.ModuleCount modules
                        </span>
                        <span class="flex items-center gap-1">
                            <i data-lucide="play-circle" class="w-3 h-3"></i>
                            @course.LessonCount lessons
                        </span>
                    </div>
                </a>
            }
        </div>
    </div>

<!-- Activity -->
    <aside>
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-base font-semibold text-gray-700 dark:text-gray-200">Activity</h2>
        </div>
        <div class="
            bg-white dark:bg-[#1e2433]
            border border-gray-100 dark:border-[#2a3147]
            rounded-xl
            divide-y divide-gray-100 dark:divide-[#2a3147]
            overflow-hidden
            ">
            @if (Model.Activity.Count == 0)
            {
                <p class="text-sm text-gray-400 dark:text-gray-500 px-5 py-6 text-center">No activity yet.</p>
            }
            else
            {
                @foreach (var item in Model.Activity)
                {
                    <div class="px-5 py-4 hover:bg-gray-50 dark:hover:bg-[#252d40] transition-colors">
                        <span class="inline-block text-[10px] font-bold uppercase tracking-widest text-blue-500 dark:text-blue-400 mb-1">@item.Type</span>
                        <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug">@item.Title</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 leading-relaxed">@item.Detail</p>
                        <time class="text-[11px] text-gray-400 dark:text-gray-500 mt-1.5 block">
                            @item.At.ToLocalTime().ToString("MMM d, h:mm tt")
                        </time>
                    </div>
                }
            }
        </div>
    </aside>

</div>