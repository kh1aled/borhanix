@model AiAssistantViewModel
@{
    ViewData["Title"] = "AI Assistant";
    ViewData["PageTitle"] = "DeepSeek AI assistant";
}

<section class="ai-shell">
    <div class="chat-panel">
        <div class="section-heading with-actions">
            <div>
                <span class="badge"><i data-lucide="sparkles"></i>@Model.Model</span>
                <h2>LMS assistant</h2>
            </div>
        </div>

        <div class="messages">
            @if (Model.Messages.Count == 0)
            {
                <div class="empty-state compact">
                    <i data-lucide="messages-square"></i>
                    <h2>Ask about your LMS work</h2>
                    <p>Use it for lesson explanations, quiz practice, assignments, grades, attendance, and project planning.</p>
                </div>
            }
            else
            {
                @foreach (var message in Model.Messages)
                {
                    <article class="message @message.Role">
                        <span>@message.Role</span>
                        <p>@message.Content</p>
                    </article>
                }
            }
        </div>
    </div>

    <form class="prompt-panel" asp-action="Ask" method="post">
        <input type="hidden" asp-for="ConversationId" />
        <label asp-for="Prompt">Prompt</label>
        <textarea asp-for="Prompt" rows="8" placeholder="Explain today's module, generate quiz practice, review my progress, or help plan the project..."></textarea>
        <button class="button" type="submit"><i data-lucide="send"></i>Ask DeepSeek</button>
    </form>
</section>
