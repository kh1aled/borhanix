@model CourseEditViewModel
@{
    ViewData["Title"] = "Edit course";
    ViewData["PageTitle"] = "Edit course";
}

<form class="editor-panel" asp-action="EditCourse" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="form-heading">
        <span class="badge"><i data-lucide="pencil"></i> Course editor</span>
        <h2>@Model.Title</h2>
    </div>
    <partial name="_CourseEditorFields" model="Model" />
    <button class="button" type="submit"><i data-lucide="save"></i>Save changes</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
