@model LessonEditViewModel
@{
    ViewData["Title"] = "Edit lesson";
    ViewData["PageTitle"] = "Edit lesson";
}

<form class="editor-panel" asp-action="EditLesson" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ModuleId" />
    <input type="hidden" asp-for="CourseId" />
    <input type="hidden" asp-for="VideoDurationSeconds" id="VideoDurationSeconds" />
    <div class="form-heading">
        <span class="badge"><i data-lucide="pencil"></i> Lesson editor</span>
        <h2>@Model.Title</h2>
    </div>
    <div class="form-grid">
        <div>
            <label asp-for="Title">Title</label>
            <input asp-for="Title" />
        </div>
        <div>
            <label asp-for="DurationMinutes">Duration (minutes, fallback)</label>
            <input asp-for="DurationMinutes" type="number" />
        </div>
        <div>
            <label asp-for="VideoUrl">Video URL</label>
            <input asp-for="VideoUrl" id="VideoUrl" placeholder="Video URL or upload below" />
        </div>
        <div>
            <label asp-for="ResourceUrl">Resource URL</label>
            <input asp-for="ResourceUrl" />
        </div>
        <div>
            <label asp-for="VideoFile">Upload video</label>
            <input asp-for="VideoFile" type="file" accept=".mp4,.webm,.mov,.m4v" id="VideoFile" />
        </div>
        <div class="full-width">
            <label asp-for="Content">Content</label>
            <textarea asp-for="Content" rows="8"></textarea>
        </div>
    </div>
    <p id="duration-preview">Stored video duration: @(Model.VideoDurationSeconds?.ToString() ?? "not set") seconds</p>
    <div class="button-row">
        <button class="button" type="submit"><i data-lucide="save"></i>Save changes</button>
        <a class="button button-ghost" asp-action="Index">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const urlInput = document.getElementById('VideoUrl');
            const fileInput = document.getElementById('VideoFile');
            const hidden = document.getElementById('VideoDurationSeconds');
            const preview = document.getElementById('duration-preview');

            function setDuration(seconds) {
                if (!seconds || seconds <= 0) return;
                hidden.value = Math.round(seconds);
                preview.textContent = `Stored video duration: ${Math.round(seconds)} seconds`;
            }

            function probeUrl(url) {
                if (!url) return;
                const video = document.createElement('video');
                video.preload = 'metadata';
                video.onloadedmetadata = () => setDuration(video.duration);
                video.src = url;
            }

            urlInput?.addEventListener('change', () => probeUrl(urlInput.value));
            fileInput?.addEventListener('change', () => {
                const file = fileInput.files?.[0];
                if (!file) return;
                const video = document.createElement('video');
                video.preload = 'metadata';
                video.onloadedmetadata = () => setDuration(video.duration);
                video.src = URL.createObjectURL(file);
            });

            if (urlInput?.value) probeUrl(urlInput.value);
        })();
    </script>
}
