@model CourseEditViewModel
@{
    ViewData["Title"] = "New course";
    ViewData["PageTitle"] = "Create course";
}

<form class="editor-panel" asp-action="CreateCourse" method="post">
    <div class="form-heading">
        <span class="badge"><i data-lucide="plus"></i> Course builder</span>
        <h2>New LMS course</h2>
    </div>
    <partial name="_CourseEditorFields" model="Model" />

    <button class="button" type="submit"><i data-lucide="save"></i>Create course</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
