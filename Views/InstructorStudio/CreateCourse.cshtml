@model CourseEditViewModel
@{
    ViewData["Title"] = "New course";
    ViewData["PageTitle"] = "Create course";
}

<div class="max-w-3xl mx-auto py-8 px-4">

    @* Header *@
    <div class="mb-8">
        <div class="flex items-center gap-2 text-[11px] font-semibold tracking-widest uppercase text-primary mb-2">
            <i data-lucide="plus" class="w-3.5 h-3.5"></i>
            Course builder
        </div>
        <h1 class="text-2xl font-semibold text-zinc-900 dark:text-white tracking-tight">New LMS course</h1>
        <p class="text-sm text-zinc-500 mt-1">Fill in the details below to publish a new course.</p>
    </div>

    <form asp-action="CreateCourse" method="post" class="flex flex-col gap-6">
        <partial name="_CourseEditorFields" model="Model" />

        <div class="flex justify-end pt-2 border-t border-zinc-100 dark:border-zinc-700">
            <button type="submit"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary text-white rounded-xl text-sm font-medium hover:opacity-90 transition-opacity">
                <i data-lucide="save" class="w-4 h-4"></i>
                Create course
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}