@model IReadOnlyCollection<Course>
@{
    ViewData["Title"] = "Instructor Studio";
    ViewData["PageTitle"] = "Instructor studio";
}

@* Page header *@
<div class="flex items-start justify-between gap-4 flex-wrap mb-8">
    <div>
        <div class="flex items-center gap-1.5 text-[11px] font-semibold tracking-widest uppercase text-gray-400 mb-1.5">
            <i data-lucide="monitor" class="w-3.5 h-3.5"></i>
            Instructor Studio
        </div>
        <h1 class="text-[22px] font-semibold text-gray-900 dark:text-white tracking-tight">Courses & content</h1>
        <p class="text-sm text-gray-500 mt-0.5">Manage modules, lessons, and assignments</p>
    </div>
    <a asp-action="CreateCourse"
       class="inline-flex items-center gap-1.5 px-4 py-2.5 bg-primary text-white text-sm font-medium rounded-xl hover:opacity-90 transition-opacity">
        <i data-lucide="plus" class="w-4 h-4"></i>
        New course
    </a>
</div>

@* Course grid *@
@if (!Model.Any())
{
    <div class="flex flex-col items-center justify-center text-center py-20 border border-dashed border-gray-200 dark:border-gray-700 rounded-2xl">
        <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-4">
            <i data-lucide="layout-grid" class="w-6 h-6 text-primary"></i>
        </div>
        <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-1">No courses yet</h3>
        <p class="text-sm text-gray-500 mb-5 max-w-sm">Create your first course to start building modules, lessons, and assignments for your students.</p>
        <a asp-action="CreateCourse"
           class="inline-flex items-center gap-1.5 px-4 py-2.5 bg-primary text-white text-sm font-medium rounded-xl hover:opacity-90 transition-opacity">
            <i data-lucide="plus" class="w-4 h-4"></i>
            Create your first course
        </a>
    </div>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
        @foreach (var course in Model)
        {
            var moduleCount = course.Modules?.Count ?? 0;
            var lessonCount = course.Modules?.Sum(m => m.Lessons?.Count ?? 0) ?? 0;
            @* NOTE: adjust `course.Assignments` below to match your actual navigation property name if it differs *@
            var assignmentCount = course.Assignments?.Count ?? 0;

            <div class="flex flex-col bg-white dark:bg-gray-800/60 border border-gray-200 dark:border-gray-700 rounded-2xl overflow-hidden hover:shadow-lg hover:border-gray-300 dark:hover:border-gray-600 transition-all duration-200">

                @* Cover image *@
                <div class="relative aspect-video w-full overflow-hidden bg-gray-100 dark:bg-gray-900">
                    @if (!string.IsNullOrEmpty(course.CoverPhotoPath))
                    {
                        <img src="@Url.Content(course.CoverPhotoPath)" alt="@course.Title" class="w-full h-full object-cover" />
                    }
                    else if (!string.IsNullOrEmpty(course.HeroImageUrl))
                    {
                        <img src="@course.HeroImageUrl" alt="@course.Title" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <div class="w-full h-full flex items-center justify-center" style="background: @(course.AccentColor)1a">
                            <i data-lucide="book-open" class="w-8 h-8" style="color: @course.AccentColor"></i>
                        </div>
                    }

                    @* Publish status badge, floating over the cover *@
                    <span class="absolute top-3 left-3 inline-flex items-center gap-1 text-[10px] font-semibold px-2 py-1 rounded-full backdrop-blur-sm
                        @(course.IsPublished
                            ? "bg-emerald-500/90 text-white"
                            : "bg-gray-900/70 text-white")">
                        <i data-lucide="@(course.IsPublished ? "check-circle" : "eye-off")" class="w-3 h-3"></i>
                        @(course.IsPublished ? "Published" : "Draft")
                    </span>

                    @* Three-dot menu, floating over the cover *@
                    <details class="absolute top-3 right-3 group">
                        <summary class="list-none w-8 h-8 flex items-center justify-center rounded-full bg-white/90 dark:bg-gray-900/80 text-gray-600 dark:text-gray-300 hover:bg-white dark:hover:bg-gray-900 cursor-pointer backdrop-blur-sm transition-colors">
                            <i data-lucide="more-vertical" class="w-4 h-4"></i>
                        </summary>
                        <div class="absolute right-0 mt-2 w-44 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-lg overflow-hidden z-10 text-left">
                            <a asp-action="EditCourse" asp-route-id="@course.Id"
                               class="flex items-center gap-2 px-3.5 py-2.5 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700/60 transition-colors">
                                <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                                Edit details
                            </a>
                            <form asp-action="TogglePublish" method="post">
                                <input type="hidden" name="id" value="@course.Id" />
                                <button type="submit"
                                        class="w-full flex items-center gap-2 px-3.5 py-2.5 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700/60 transition-colors">
                                    <i data-lucide="@(course.IsPublished ? "eye-off" : "upload")" class="w-3.5 h-3.5"></i>
                                    @(course.IsPublished ? "Unpublish" : "Publish")
                                </button>
                            </form>

                            <div class="border-t border-gray-100 dark:border-gray-700"></div>

                            <form asp-action="DeleteCourse" method="post" onsubmit="return confirm('Delete this course? This cannot be undone.');">
                                <input type="hidden" name="id" value="@course.Id" />
                                <button type="submit"
                                        class="w-full flex items-center gap-2 px-3.5 py-2.5 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-950/40 transition-colors">
                                    <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                                    Delete
                                </button>
                            </form>
                        </div>
                    </details>
                </div>

                @* Card body *@
                <div class="flex flex-col flex-1 p-5">
                    <div class="flex items-center gap-1.5 flex-wrap mb-2">
                        <span class="text-[10px] font-bold tracking-widest uppercase px-2 py-0.5 rounded-md"
                              style="color: @course.AccentColor; background: @(course.AccentColor)18">
                            @course.Code
                        </span>
                        <span class="text-[11px] font-medium text-gray-500 dark:text-gray-400">@course.Category</span>
                        <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
                        <span class="text-[11px] font-medium text-gray-500 dark:text-gray-400">@course.Level</span>
                    </div>

                    <h3 class="text-[15px] font-semibold text-gray-900 dark:text-white leading-snug mb-1 line-clamp-1">@course.Title</h3>
                    <p class="text-sm text-gray-500 dark:text-gray-400 leading-snug line-clamp-2 mb-4">@course.Summary</p>

                    @* Stats row *@
                    <div class="grid grid-cols-3 gap-2 mb-5 mt-auto">
                        <div class="flex flex-col items-center justify-center gap-0.5 py-2.5 rounded-xl bg-gray-50 dark:bg-gray-900/40">
                            <div class="flex items-center gap-1 text-gray-800 dark:text-gray-100">
                                <i data-lucide="layers" class="w-3.5 h-3.5 text-gray-400"></i>
                                <span class="text-sm font-semibold">@moduleCount</span>
                            </div>
                            <span class="text-[10px] text-gray-400 uppercase tracking-wide">Modules</span>
                        </div>
                        <div class="flex flex-col items-center justify-center gap-0.5 py-2.5 rounded-xl bg-gray-50 dark:bg-gray-900/40">
                            <div class="flex items-center gap-1 text-gray-800 dark:text-gray-100">
                                <i data-lucide="play-circle" class="w-3.5 h-3.5 text-gray-400"></i>
                                <span class="text-sm font-semibold">@lessonCount</span>
                            </div>
                            <span class="text-[10px] text-gray-400 uppercase tracking-wide">Lessons</span>
                        </div>
                        <div class="flex flex-col items-center justify-center gap-0.5 py-2.5 rounded-xl bg-gray-50 dark:bg-gray-900/40">
                            <div class="flex items-center gap-1 text-gray-800 dark:text-gray-100">
                                <i data-lucide="clipboard-list" class="w-3.5 h-3.5 text-gray-400"></i>
                                <span class="text-sm font-semibold">@assignmentCount</span>
                            </div>
                            <span class="text-[10px] text-gray-400 uppercase tracking-wide">Assignments</span>
                        </div>
                    </div>

                    @* Actions *@
                    <div class="flex items-center gap-2">
                        @* NOTE: requires a new "ManageContent" GET action that returns the page below, keyed by course id *@
                        <a asp-action="ManageContent" asp-route-id="@course.Id"
                           class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2.5 bg-primary text-white text-sm font-medium rounded-xl hover:opacity-90 transition-opacity">
                            <i data-lucide="folder-cog" class="w-4 h-4"></i>
                            Manage content
                        </a>
                        <a asp-controller="Courses" asp-action="Details" asp-route-id="@course.Id"
                           class="inline-flex items-center justify-center gap-1.5 px-3 py-2.5 border border-gray-200 dark:border-gray-600 rounded-xl text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                            <i data-lucide="external-link" class="w-4 h-4"></i>
                            Preview
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
