@model ModuleEditViewModel

@{
    ViewData["Title"] = "Edit Module";
    ViewData["PageTitle"] = "Edit Module";
}

<div class="mx-auto py-8 px-4 bg-white dark:bg-gray-700 rounded-2xl shadow-lg">

    @* Header *@
    <div class="mb-8">
        <div class="flex items-center gap-2 text-[11px] font-semibold tracking-widest uppercase text-primary dark:text-white/50 mb-2">
            <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
            Module editor
        </div>

        <h1 class="text-2xl font-semibold text-gray-900 dark:text-white tracking-tight">
            @Model.Title
        </h1>

        <p class="text-sm text-gray-500 mt-1">
            Update the module information and save your changes.
        </p>
    </div>

    <form asp-action="EditModule"
          method="post"
          class="flex flex-col gap-6">

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CourseId" />

        <div asp-validation-summary="ModelOnly"
             class="px-4 py-3 bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 rounded-xl text-sm text-red-600 dark:text-red-400 empty:hidden">
        </div>

        <div class="bg-white dark:bg-gray-800/60 border border-gray-200 dark:border-gray-700 rounded-2xl overflow-hidden">

            <div class="px-5 py-3.5 border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/40">
                <span class="text-[11px] font-semibold tracking-widest uppercase text-gray-400">
                    Module Information
                </span>
            </div>

            <div class="p-5 grid grid-cols-1 gap-5">

                <div class="flex flex-col gap-1.5">
                    <label asp-for="Title"
                           class="text-xs font-medium text-gray-600 dark:text-gray-400">
                    </label>

                    <input asp-for="Title"
                           placeholder="Module title"
                           class="px-3 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg text-sm placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all" />

                    <span asp-validation-for="Title"
                          class="text-xs text-red-500"></span>
                </div>

                <div class="flex flex-col gap-1.5">

                    <label asp-for="Summary"
                           class="text-xs font-medium text-gray-600 dark:text-gray-400">
                    </label>

                    <textarea asp-for="Summary"
                              rows="5"
                              placeholder="Short description about this module..."
                              class="px-3 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg text-sm placeholder:text-gray-400 resize-none focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"></textarea>

                    <span asp-validation-for="Summary"
                          class="text-xs text-red-500"></span>

                </div>

            </div>

        </div>

        <div class="flex justify-between items-center pt-2 border-t border-gray-100 dark:border-gray-700">

            <a asp-action="ManageContent"
               asp-route-id="@Model.CourseId"
               class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
                Back
            </a>

            <button type="submit"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary text-white rounded-xl text-sm font-medium hover:opacity-90 transition-opacity">

                <i data-lucide="save" class="w-4 h-4"></i>
                Save Changes

            </button>

        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}