@model ModuleEditViewModel
@{
    ViewData["Title"] = "Edit module";
    ViewData["PageTitle"] = "Edit module";
}

<form class="editor-panel" asp-action="EditModule" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CourseId" />
    <div class="form-heading">
        <span class="badge"><i data-lucide="pencil"></i> Module editor</span>
        <h2>@Model.Title</h2>
    </div>
    <div class="form-grid">
        <div>
            <label asp-for="Title">Title</label>
            <input asp-for="Title" />
        </div>
        <div>
            <label asp-for="Summary">Summary</label>
            <input asp-for="Summary" />
        </div>
    </div>
    <div class="button-row">
        <button class="button" type="submit"><i data-lucide="save"></i>Save changes</button>
        <a class="button button-ghost" asp-action="Index">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
