@model SandboxCheckoutViewModel
@{
    ViewData["Title"] = "Sandbox Checkout";
    ViewData["PageTitle"] = "Sandbox Checkout";
}

<div class="mx-auto grid max-w-5xl gap-6 lg:grid-cols-[1fr_320px]">
    <form asp-controller="Cart" asp-action="Checkout" method="post" class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-gray-900">
        <div asp-validation-summary="ModelOnly" class="mb-4 rounded-xl bg-red-50 p-3 text-sm text-red-600 empty:hidden dark:bg-red-500/10 dark:text-red-300"></div>
        <p class="text-[11px] font-semibold uppercase tracking-widest text-slate-400">Free test mode</p>
        <h1 class="mt-1 text-2xl font-bold text-slate-900 dark:text-white">Pay with a sandbox card</h1>
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">No payment gateway is contacted. Use 4242 4242 4242 4242 for success or 4000 0000 0000 0002 to test a decline.</p>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <div class="sm:col-span-2">
                <label asp-for="CardholderName" class="text-xs font-semibold text-slate-600 dark:text-slate-300"></label>
                <input asp-for="CardholderName" class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-slate-700 dark:bg-slate-800" />
                <span asp-validation-for="CardholderName" class="text-xs text-red-500"></span>
            </div>
            <div class="sm:col-span-2">
                <label asp-for="CardNumber" class="text-xs font-semibold text-slate-600 dark:text-slate-300"></label>
                <input asp-for="CardNumber" class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-slate-700 dark:bg-slate-800" />
                <span asp-validation-for="CardNumber" class="text-xs text-red-500"></span>
            </div>
            <div>
                <label asp-for="Expiry" class="text-xs font-semibold text-slate-600 dark:text-slate-300"></label>
                <input asp-for="Expiry" class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-slate-700 dark:bg-slate-800" />
                <span asp-validation-for="Expiry" class="text-xs text-red-500"></span>
            </div>
            <div>
                <label asp-for="Cvc" class="text-xs font-semibold text-slate-600 dark:text-slate-300"></label>
                <input asp-for="Cvc" class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-slate-700 dark:bg-slate-800" />
                <span asp-validation-for="Cvc" class="text-xs text-red-500"></span>
            </div>
        </div>

        <button type="submit" class="mt-6 flex w-full items-center justify-center gap-2 rounded-xl bg-primary px-4 py-3 text-sm font-bold text-white transition hover:brightness-110">
            <i data-lucide="lock" class="h-4 w-4"></i>
            Complete test payment
        </button>
    </form>

    <aside class="h-fit rounded-2xl border border-slate-100 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-gray-900">
        <h2 class="font-bold text-slate-900 dark:text-white">Order summary</h2>
        <div class="mt-4 space-y-3">
            @foreach (var item in Model.Items)
            {
                <div class="flex justify-between gap-3 text-sm">
                    <span class="text-slate-600 dark:text-slate-300">@item.Title</span>
                    <span class="font-semibold text-slate-900 dark:text-white">@item.PriceLabel</span>
                </div>
            }
        </div>
        <div class="mt-5 flex items-center justify-between border-t border-slate-100 pt-4 dark:border-slate-800">
            <span class="text-sm font-semibold text-slate-500">Total</span>
            <span class="text-xl font-black text-primary">@Model.TotalLabel</span>
        </div>
    </aside>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
