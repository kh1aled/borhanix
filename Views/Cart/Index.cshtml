@model CartViewModel
@{
    ViewData["Title"] = "Shopping Cart";
    ViewData["PageTitle"] = "Shopping Cart";
}

<div class="mx-auto max-w-5xl space-y-6">
    <div class="flex flex-col gap-3 rounded-2xl border border-slate-100 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-gray-900 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <p class="text-[11px] font-semibold uppercase tracking-widest text-slate-400">Checkout</p>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Your cart</h1>
        </div>
        <a asp-controller="Courses" asp-action="Index" class="inline-flex items-center justify-center gap-2 rounded-xl border border-slate-200 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">
            <i data-lucide="book-open" class="h-4 w-4"></i>
            Browse courses
        </a>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="rounded-2xl border border-dashed border-slate-300 bg-white p-10 text-center dark:border-slate-700 dark:bg-gray-900">
            <i data-lucide="shopping-cart" class="mx-auto h-12 w-12 text-slate-300"></i>
            <h2 class="mt-4 text-xl font-bold text-slate-900 dark:text-white">Your cart is empty</h2>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Add courses, then use the sandbox checkout to enroll instantly.</p>
        </div>
    }
    else
    {
        <div class="grid gap-6 lg:grid-cols-[1fr_320px]">
            <div class="space-y-3">
                @foreach (var item in Model.Items)
                {
                    <div class="flex gap-4 rounded-2xl border border-slate-100 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-gray-900">
                        <div class="h-24 w-32 shrink-0 overflow-hidden rounded-xl bg-slate-100 dark:bg-slate-800">
                            @if (!string.IsNullOrWhiteSpace(item.CoverImageUrl))
                            {
                                <img src="@item.CoverImageUrl" alt="@item.Title" class="h-full w-full object-cover" />
                            }
                        </div>
                        <div class="min-w-0 flex-1">
                            <p class="text-xs font-semibold uppercase tracking-wide text-primary">@item.Code</p>
                            <h2 class="mt-1 font-bold text-slate-900 dark:text-white">@item.Title</h2>
                            <p class="mt-1 line-clamp-2 text-sm text-slate-500 dark:text-slate-400">@item.Summary</p>
                            <p class="mt-3 text-sm font-bold text-slate-900 dark:text-white">@item.PriceLabel</p>
                        </div>
                        <form asp-controller="Cart" asp-action="Remove" method="post">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="rounded-lg p-2 text-slate-400 transition hover:bg-red-50 hover:text-red-600 dark:hover:bg-red-500/10">
                                <i data-lucide="trash-2" class="h-5 w-5"></i>
                            </button>
                        </form>
                    </div>
                }
            </div>

            <aside class="h-fit rounded-2xl border border-slate-100 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-gray-900">
                <div class="flex items-center justify-between border-b border-slate-100 pb-4 dark:border-slate-800">
                    <span class="text-sm font-semibold text-slate-500 dark:text-slate-400">Total</span>
                    <span class="text-xl font-black text-primary">@Model.TotalLabel</span>
                </div>
                <a asp-controller="Cart" asp-action="Checkout" class="mt-5 flex w-full items-center justify-center gap-2 rounded-xl bg-primary px-4 py-3 text-sm font-bold text-white transition hover:brightness-110">
                    <i data-lucide="credit-card" class="h-4 w-4"></i>
                    Sandbox checkout
                </a>
                <form asp-controller="Cart" asp-action="Clear" method="post" class="mt-2">
                    <button type="submit" class="flex w-full items-center justify-center gap-2 rounded-xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-600 transition hover:bg-slate-50 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800">
                        Clear cart
                    </button>
                </form>
            </aside>
        </div>
    }
</div>
