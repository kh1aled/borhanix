@model CourseDetailsViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = Model.Course.Title;
    ViewData["PageTitle"] = Model.Course.Code;
    var totalLessons = Model.Course.Modules.Sum(x => x.Lessons.Count);
    var approvedStudents = Model.Course.Enrollments.Count(x => x.Status == EnrollmentStatus.Approved);
    var coverImage = CourseMedia.ResolveCoverImage(Model.Course);
    var tokens = Antiforgery.GetAndStoreTokens(Context);
    var trackProgress = User.IsInRole(AppRoles.Student) && Model.Enrollment?.Status == EnrollmentStatus.Approved;
}

<section class="course-hero" style="--accent:@Model.Course.AccentColor">
    @if (!string.IsNullOrWhiteSpace(coverImage))
    {
        <img src="@coverImage" alt="@Model.Course.Title cover" style="max-width:220px;border-radius:12px;margin-bottom:1rem;" />
    }
    <div>
        <span class="badge"><i data-lucide="book-open"></i>@Model.Course.Category</span>
        <h2>@Model.Course.Title</h2>
        <p>@Model.Course.Description</p>
        <div class="course-meta">
            <span>@Model.Course.Level</span>
            <span>@Model.Course.Modules.Count modules</span>
            <span>@Model.Course.Modules.Sum(x => x.Lessons.Count) lessons</span>
            <span>@Model.Course.Enrollments.Count(x => x.Status == EnrollmentStatus.Approved) approved students</span>
        </div>
        @if (Model.CompletionStatus is not null)
        {
            <div class="course-meta">
                <span>Lessons: @Model.CompletionStatus.CompletedLessons / @Model.CompletionStatus.TotalLessons</span>
                <span>Quizzes passed: @Model.CompletionStatus.PassedQuizzes / @Model.CompletionStatus.TotalQuizzes</span>
            </div>
        }
    </div>
    <div class="hero-actions">
        @if (Model.CanRequestEnrollment)
        {
            <form asp-action="Enroll" method="post">
                <input type="hidden" name="id" value="@Model.Course.Id" />
                @Html.AntiForgeryToken()
                <button class="button" type="submit"><i data-lucide="send"></i>Request enrollment</button>
            </form>
        }
        else if (Model.Enrollment is not null)
        {
            <span class="status-pill">@Model.Enrollment.Status</span>
        }
        @if (Model.CanGenerateCertificate)
        {
            <form asp-controller="Certificates" asp-action="Generate" method="post">
                <input type="hidden" name="courseId" value="@Model.Course.Id" />
                @Html.AntiForgeryToken()
                <button class="button" type="submit"><i data-lucide="award"></i>Generate certificate</button>
            </form>
        }
        else if (Model.CertificateId is not null)
        {
            <a class="button" asp-controller="Certificates" asp-action="Show" asp-route-id="@Model.CertificateId"><i data-lucide="award"></i>View certificate</a>
        }
        @if (Model.CanManage)
        {
            <a class="button button-ghost" asp-controller="Lessons" asp-action="Progress" asp-route-courseId="@Model.Course.Id"><i data-lucide="bar-chart-3"></i>Lesson progress</a>
            <a class="button button-ghost" asp-controller="InstructorStudio" asp-action="Index"><i data-lucide="settings"></i>Manage</a>
        }
    </div>
</section>

            





<section class="content-grid wide-left">
    <div>
        <div class="section-heading">
            <h2>Modules and lessons</h2>
        </div>
        <div class="timeline-list">
            @foreach (var module in Model.Course.Modules.OrderBy(x => x.SortOrder))
            {
                <article class="timeline-item">
                    <span>@module.SortOrder</span>
                    <div>
                        <h3>@module.Title</h3>
                        <p>@module.Summary</p>
                        <ul class="lesson-list">
                            @foreach (var lesson in module.Lessons.OrderBy(x => x.SortOrder))
                            {
                                Model.LessonProgressMap.TryGetValue(lesson.Id, out var progress);
                                var lessonComplete = progress?.IsComplete == true || Model.CompletedLessonIds.Contains(lesson.Id);
                                var durationSeconds = lesson.VideoDurationSeconds ?? (lesson.DurationMinutes * 60);
                                var initialMax = progress?.MaxWatchedSeconds ?? 0;
                                var viewingPercent = progress?.ViewingPercent ?? 0;
                                var video = CourseMedia.ResolveLessonVideo(lesson.VideoUrl);
                                <li class="lesson-row @(lessonComplete ? "lesson-complete" : "")" data-lesson-row="@lesson.Id">
                                    <div>
                                        <i data-lucide="@(lessonComplete ? "check-circle-2" : "play-circle")"></i>
                                        <strong>@lesson.Title</strong>
                                        <small>@lesson.DurationMinutes min</small>
                                        <span class="status-pill" data-complete-pill @(lessonComplete ? "" : "hidden")>Completed</span>
                                    </div>
                                    @if (trackProgress && !lessonComplete)
                                    {
                                        <div class="lesson-progress-bar-wrap">
                                            <div class="lesson-progress-bar" data-progress-bar="@lesson.Id" style="width:@viewingPercent%"></div>
                                        </div>
                                        <small data-progress-label="@lesson.Id">@Math.Round(viewingPercent)% watched</small>
                                    }
                                    @if (video.Kind == LessonVideoKind.Direct)
                                    {
                                        <video controls preload="metadata"
                                               src="@video.PlaybackUrl"
                                               data-course-id="@Model.Course.Id"
                                               data-lesson-id="@lesson.Id"
                                               data-duration-seconds="@durationSeconds"
                                               data-initial-max="@initialMax"
                                               data-tracking="@(trackProgress && !lessonComplete ? "on" : "off")"></video>
                                    }
                                    else if (video.Kind == LessonVideoKind.Embed)
                                    {
                                        <div class="lesson-video-frame"
                                             data-content-tracker="@(trackProgress && !lessonComplete ? "on" : null)"
                                             data-course-id="@(trackProgress && !lessonComplete ? Model.Course.Id : null)"
                                             data-lesson-id="@(trackProgress && !lessonComplete ? lesson.Id : null)"
                                             data-duration-seconds="@(trackProgress && !lessonComplete ? durationSeconds : null)"
                                             data-initial-max="@(trackProgress && !lessonComplete ? initialMax : null)">
                                            <iframe src="@video.PlaybackUrl"
                                                    title="@lesson.Title video"
                                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                                    allowfullscreen></iframe>
                                        </div>
                                    }
                                    else if (video.Kind == LessonVideoKind.ExternalLink)
                                    {
                                        <a class="button button-small button-ghost" href="@video.PlaybackUrl" target="_blank" rel="noopener">
                                            <i data-lucide="external-link"></i>Open video
                                        </a>
                                        @if (trackProgress && !lessonComplete)
                                        {
                                            <div class="lesson-content-tracker"
                                                 data-content-tracker
                                                 data-course-id="@Model.Course.Id"
                                                 data-lesson-id="@lesson.Id"
                                                 data-duration-seconds="@durationSeconds"
                                                 data-initial-max="@initialMax">
                                                @lesson.Content
                                            </div>
                                        }
                                    }
                                    else if (trackProgress && !lessonComplete)
                                    {
                                        <div class="lesson-content-tracker"
                                             data-content-tracker
                                             data-course-id="@Model.Course.Id"
                                             data-lesson-id="@lesson.Id"
                                             data-duration-seconds="@durationSeconds"
                                             data-initial-max="@initialMax">
                                            @lesson.Content
                                        </div>
                                    }
                                    else
                                    {
                                        <p>@lesson.Content</p>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                </article>
            }
        </div>
    </div>

    <aside class="activity-panel">
        <div class="section-heading">
            <h2>Assessments</h2>
        </div>
        @foreach (var assignment in Model.Course.Assignments.OrderBy(x => x.DueAt))
        {
            <div class="activity-item">
                <span>Assignment</span>
                <strong>@assignment.Title</strong>
                <small>@assignment.MaxPoints points · @assignment.DeadlineHours h personal window</small>
                <a asp-controller="Assignments" asp-action="Details" asp-route-id="@assignment.Id">Open assignment</a>
            </div>
        }
        @foreach (var quiz in Model.Course.Quizzes)
        {
            var completed = Model.QuizAttemptIds.TryGetValue(quiz.Id, out var attemptId);
            <div class="activity-item">
                <span>Quiz</span>
                <strong>@quiz.Title</strong>
                <small>@quiz.Questions.Count questions</small>
                <time>@quiz.TimeLimitMinutes min</time>
                @if (completed)
                {
                    <a asp-controller="Quizzes" asp-action="Review" asp-route-id="@attemptId">Review quiz</a>
                }
                else
                {
                    <a asp-controller="Quizzes" asp-action="Take" asp-route-id="@quiz.Id">Open quiz</a>
                }
            </div>
        }
    </aside>
</section>

@if (trackProgress)
{
    <input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />
}

@section Scripts {
    @if (trackProgress)
    {
        <script src="~/js/lesson-progress.js" asp-append-version="true"></script>
    }
    <style>
        .lesson-progress-bar-wrap {
        background: #e2e8f0;
        border-radius: 999px;
        height: 8px;
        margin: 0.5rem 0;
        overflow: hidden;
        }

        .lesson-progress-bar {
        background: #0ea5e9;
        height: 100%;
        transition: width 0.3s ease;
        }

        .lesson-complete .lesson-progress-bar {
        background: #22c55e;
        }

        .lesson-video-frame {
        aspect-ratio: 16 / 9;
        background: #0f172a;
        border-radius: 8px;
        margin-top: 0.75rem;
        overflow: hidden;
        width: min(100%, 760px);
        }

        .lesson-video-frame iframe {
        border: 0;
        height: 100%;
        width: 100%;
        }

    </style>
}
