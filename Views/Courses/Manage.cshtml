@model IReadOnlyCollection<Course>
@{
    ViewData["Title"] = "Manage courses";
    ViewData["PageTitle"] = "Course management";
}

<section class="section-heading with-actions">
    <div>
        <span class="badge"><i data-lucide="settings"></i> Instructor tools</span>
        <h2>Manage courses</h2>
    </div>
    <a class="button" asp-controller="InstructorStudio" asp-action="CreateCourse"><i data-lucide="plus"></i>New course</a>
</section>

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>Course</th>
                <th>Modules</th>
                <th>Lessons</th>
                <th>Enrollments</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var course in Model)
            {
                <tr>
                    <td><strong>@course.Code</strong><br /><span>@course.Title</span></td>
                    <td>@course.Modules.Count</td>
                    <td>@course.Modules.Sum(x => x.Lessons.Count)</td>
                    <td>@course.Enrollments.Count(x => x.Status == EnrollmentStatus.Approved)</td>
                    <td><span class="status-pill">@(course.IsPublished ? "Published" : "Draft")</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>
