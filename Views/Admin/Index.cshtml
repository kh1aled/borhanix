@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin";
    ViewData["PageTitle"] = "Admin control";
}

@* Header *@
<div class="flex items-start justify-between gap-4 flex-wrap mb-8">
    <div>
        <div class="flex items-center gap-1.5 text-[11px] font-semibold tracking-widest uppercase text-primary mb-1.5">
            <i data-lucide="shield" class="w-3.5 h-3.5"></i>
            Control panel
        </div>
        <h1 class="text-[22px] font-semibold text-gray-900 dark:text-white tracking-tight">Admin dashboard</h1>
        <p class="text-sm text-gray-500 mt-0.5">Platform overview and account management.</p>
    </div>
    <div class="flex items-center gap-2">
        <a asp-action="Users"
           class="inline-flex items-center gap-1.5 px-4 py-2.5 border border-gray-200 dark:border-gray-600 rounded-xl text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
            <i data-lucide="users" class="w-4 h-4"></i>
            Manage users
        </a>
        <a asp-controller="InstructorStudio" asp-action="Index"
           class="inline-flex items-center gap-1.5 px-4 py-2.5 bg-primary text-white rounded-xl text-sm font-medium hover:opacity-90 transition-opacity">
            <i data-lucide="book-open-check" class="w-4 h-4"></i>
            Manage courses
        </a>
    </div>
</div>

@* Stats grid *@
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">

    <div class="bg-white dark:bg-gray-800/60 border border-gray-200 dark:border-gray-700 rounded-2xl p-5">
        <div class="w-9 h-9 rounded-xl bg-cyan-50 dark:bg-cyan-950 flex items-center justify-center mb-4">
            <i data-lucide="users" class="w-4 h-4 text-cyan-600 dark:text-cyan-400"></i>
        </div>
        <p class="text-xs font-medium text-gray-400 uppercase tracking-widest mb-1">Users</p>
        <p class="text-3xl font-semibold text-gray-900 dark:text-white tracking-tight">@Model.UserCount</p>
        <p class="text-xs text-gray-400 mt-1">Identity accounts</p>
    </div>

    <div class="bg-white dark:bg-gray-800/60 border border-gray-200 dark:border-gray-700 rounded-2xl p-5">
        <div class="w-9 h-9 rounded-xl bg-emerald-50 dark:bg-emerald-950 flex items-center justify-center mb-4">
            <i data-lucide="book-open" class="w-4 h-4 text-emerald-600 dark:text-emerald-400"></i>
        </div>
        <p class="text-xs font-medium text-gray-400 uppercase tracking-widest mb-1">Courses</p>
        <p class="text-3xl font-semibold text-gray-900 dark:text-white tracking-tight">@Model.CourseCount</p>
        <p class="text-xs text-gray-400 mt-1">LMS catalog</p>
    </div>

    <div class="bg-white dark:bg-gray-800/60 border border-gray-200 dark:border-gray-700 rounded-2xl p-5 relative">
        <div class="w-9 h-9 rounded-xl bg-amber-50 dark:bg-amber-950 flex items-center justify-center mb-4">
            <i data-lucide="badge-alert" class="w-4 h-4 text-amber-600 dark:text-amber-400"></i>
        </div>
        <p class="text-xs font-medium text-gray-400 uppercase tracking-widest mb-1">Pending</p>
        <p class="text-3xl font-semibold text-gray-900 dark:text-white tracking-tight">@Model.PendingEnrollments</p>
        <p class="text-xs text-gray-400 mt-1">Enrollment approvals</p>
        @if (Model.PendingEnrollments > 0)
        {
            <span class="absolute top-4 right-4 w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
        }
    </div>

    <div class="bg-white dark:bg-gray-800/60 border border-gray-200 dark:border-gray-700 rounded-2xl p-5">
        <div class="w-9 h-9 rounded-xl bg-violet-50 dark:bg-violet-950 flex items-center justify-center mb-4">
            <i data-lucide="qr-code" class="w-4 h-4 text-violet-600 dark:text-violet-400"></i>
        </div>
        <p class="text-xs font-medium text-gray-400 uppercase tracking-widest mb-1">Sessions</p>
        <p class="text-3xl font-semibold text-gray-900 dark:text-white tracking-tight">@Model.AttendanceSessions</p>
        <p class="text-xs text-gray-400 mt-1">Attendance events</p>
    </div>

</div>

@* Recent users *@
<div class="bg-white dark:bg-gray-800/60 border border-gray-200 dark:border-gray-700 rounded-2xl overflow-hidden">

    @* Table header *@
    <div class="flex items-center justify-between gap-4 px-5 py-4 border-b border-gray-100 dark:border-gray-700">
        <div class="flex items-center gap-2">
            <i data-lucide="users-round" class="w-4 h-4 text-primary"></i>
            <span class="text-sm font-semibold text-gray-800 dark:text-gray-100">Recent accounts</span>
        </div>
        <a asp-action="Users"
           class="text-xs font-medium text-primary hover:opacity-75 transition-opacity inline-flex items-center gap-1">
            View all
            <i data-lucide="arrow-right" class="w-3 h-3"></i>
        </a>
    </div>

    @* Table *@
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/40">
                    <th class="text-left text-[11px] font-semibold tracking-widest uppercase text-gray-400 px-5 py-3">Name</th>
                    <th class="text-left text-[11px] font-semibold tracking-widest uppercase text-gray-400 px-5 py-3">Email</th>
                    <th class="text-left text-[11px] font-semibold tracking-widest uppercase text-gray-400 px-5 py-3">Created</th>
                    <th class="text-left text-[11px] font-semibold tracking-widest uppercase text-gray-400 px-5 py-3">Last active</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700/60">
                @foreach (var user in Model.RecentUsers)
                {
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
                        <td class="px-5 py-3.5">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                                    <span class="text-[11px] font-semibold text-primary">
                                        @(user.FullName.Split(' ').FirstOrDefault()?[0])@(user.FullName.Split(' ').Skip(1).FirstOrDefault()?[0])
                                    </span>
                                </div>
                                <span class="font-medium text-gray-800 dark:text-gray-100">@user.FullName</span>
                            </div>
                        </td>
                        <td class="px-5 py-3.5 text-gray-500 dark:text-gray-400">@user.Email</td>
                        <td class="px-5 py-3.5 text-gray-500 dark:text-gray-400">@user.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</td>
                        <td class="px-5 py-3.5">
                            @if (user.LastActiveAt.HasValue)
                            {
                                <span class="text-gray-500 dark:text-gray-400">@user.LastActiveAt.Value.ToLocalTime().ToString("MMM d, h:mm tt")</span>
                            }
                            else
                            {
                                <span class="text-gray-300 dark:text-gray-600">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>