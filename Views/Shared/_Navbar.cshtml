<header x-data="{ open: false }"
        class="sticky top-0 z-50 border-b border-border/60 bg-background/80 backdrop-blur-md">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative">
        <div class="flex h-16 items-center justify-between sm:h-20 ">

            <!-- Logo -->
            <a asp-controller="Home" asp-action="Index" class="flex shrink-0 items-center">
                <img src="~/images/borhanix-logo.png" alt="Borhanix Logo" class="h-10 w-auto" />
            </a>

            <!-- Desktop nav links -->
            <nav class="hidden sm:flex sm:items-center sm:gap-1">
                <a asp-controller="Home" asp-action="Index"
                   class="rounded-md px-3 py-2 text-sm font-medium text-primary transition-colors sm:text-base">
                    Home
                </a>
                <a asp-controller="Courses" asp-action="Index"
                   class="rounded-md px-3 py-2 text-sm font-medium text-foreground transition-colors hover:text-primary sm:text-base">
                    Courses
                </a>
                <a asp-controller="Instructors" asp-action="Index"
                   class="rounded-md px-3 py-2 text-sm font-medium text-foreground transition-colors hover:text-primary sm:text-base">
                    Instructors
                </a>
            </nav>

             


            <!-- Right side controls -->
            <div class="flex items-center gap-2 sm:gap-4">

              @*   <!-- Theme toggle -->
                <button type="button"
                        id="themeToggle"
                        aria-label="Toggle theme"
                        class="rounded-md p-2 text-foreground transition-colors hover:bg-foreground/5 hover:text-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-primary">
                    <i data-lucide="moon" id="themeIconMoon" class="size-5 sm:size-6"></i>
                    <i data-lucide="sun" id="themeIconSun" class="hidden size-5 sm:size-6"></i>
                </button> *@


                <!-- Auth buttons (desktop only) -->
                <div class="hidden items-center gap-2 sm:flex">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Dashboard" asp-action="Index"
                           class="rounded-md border-2 border-primary px-4 py-2 text-sm font-bold text-foreground transition-colors hover:bg-primary hover:text-primary-foreground sm:px-6 sm:py-2.5 sm:text-base">
                            Dashboard
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login"
                           class="px-3 py-2 text-sm font-bold text-foreground transition-colors hover:text-primary sm:text-base">
                            Log in
                        </a>
                        <a asp-controller="Account" asp-action="Register"
                           class="rounded-md border-2 border-primary px-4 py-2 text-sm font-bold text-foreground transition-colors hover:bg-primary hover:text-primary-foreground sm:px-6 sm:py-2.5 sm:text-base">
                            Sign up
                        </a>
                    }
                </div>

                <!-- Mobile menu button -->
                <button type="button"
                        id="mobileMenuButton"
                        aria-label="Open main menu"
                        aria-expanded="false"
                        class="group relative inline-flex items-center justify-center rounded-md p-2 text-foreground transition-colors hover:bg-foreground/5 hover:text-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-primary sm:hidden">
                    <i data-lucide="menu" id="menuIconOpen" class="size-6"></i>
                    <i data-lucide="x" id="menuIconClose" class="hidden size-6"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile menu panel -->
    <div id="mobileMenuPanel" class="hidden border-t border-border/60 sm:hidden">
        <div class="space-y-1 px-4 pt-3 pb-4">
            <a asp-controller="Home" asp-action="Index"
               class="block rounded-md px-3 py-2 text-base font-medium text-primary transition-colors">
                Home
            </a>
            <a asp-controller="Courses" asp-action="Index"
               class="block rounded-md px-3 py-2 text-base font-medium text-foreground transition-colors hover:text-primary">
                Courses
            </a>
            <a asp-controller="Instructors" asp-action="Index"
               class="block rounded-md px-3 py-2 text-base font-medium text-foreground transition-colors hover:text-primary">
                Instructors
            </a>
        </div>

        <div class="flex items-center gap-3 border-t border-border/60 px-4 py-4">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Dashboard" asp-action="Index"
                   class="flex-1 rounded-md border-2 border-primary px-4 py-2.5 text-center text-base font-bold text-foreground transition-colors hover:bg-primary hover:text-primary-foreground">
                    Dashboard
                </a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login"
                   class="flex-1 rounded-md px-4 py-2.5 text-center text-base font-bold text-foreground transition-colors hover:text-primary">
                    Log in
                </a>
                <a asp-controller="Account" asp-action="Register"
                   class="flex-1 rounded-md border-2 border-primary px-4 py-2.5 text-center text-base font-bold text-foreground transition-colors hover:bg-primary hover:text-primary-foreground">
                    Sign up
                </a>
            }
        </div>
    </div>
</header>
