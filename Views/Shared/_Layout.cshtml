<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DEPI LMS</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <a class="brand" asp-controller="Home" asp-action="Index">
                <span class="brand-mark">D</span>
                <span>
                    <strong>DEPI LMS</strong>
                    <small>Graduation Platform</small>
                </span>
            </a>

            <nav class="nav-stack">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Dashboard" asp-action="Index"><i data-lucide="layout-dashboard"></i><span>Dashboard</span></a>
                    <a asp-controller="Profile" asp-action="Index"><i data-lucide="circle-user-round"></i><span>Profile</span></a>
                    <a asp-controller="Courses" asp-action="Index"><i data-lucide="book-open"></i><span>Courses</span></a>
                    <a asp-controller="Attendance" asp-action="Index"><i data-lucide="qr-code"></i><span>Attendance</span></a>
                    <a asp-controller="AiAssistant" asp-action="Index"><i data-lucide="sparkles"></i><span>AI Assistant</span></a>

                    @if (User.IsInRole(AppRoles.Instructor) || User.IsInRole(AppRoles.Admin))
                    {
                        <a asp-controller="InstructorStudio" asp-action="Index"><i data-lucide="presentation"></i><span>Instructor Studio</span></a>
                        <a asp-controller="Enrollments" asp-action="Pending"><i data-lucide="user-check"></i><span>Approvals</span></a>
                    }

                    @if (User.IsInRole(AppRoles.Admin))
                    {
                        <a asp-controller="Admin" asp-action="Index"><i data-lucide="shield-check"></i><span>Admin</span></a>
                        <a asp-controller="Admin" asp-action="Users"><i data-lucide="users-round"></i><span>Users</span></a>
                    }
                }
                else
                {
                    <a asp-controller="Home" asp-action="Index"><i data-lucide="home"></i><span>Overview</span></a>
                    <a asp-controller="Account" asp-action="Login"><i data-lucide="log-in"></i><span>Login</span></a>
                    <a asp-controller="Account" asp-action="Register"><i data-lucide="user-plus"></i><span>Register</span></a>
                }
            </nav>
        </aside>

        <main class="main">
            <header class="topbar">
                <div>
                    <p class="eyebrow">@DateTime.Now.ToString("dddd, MMM d")</p>
                    <h1>@(ViewData["PageTitle"] ?? ViewData["Title"] ?? "DEPI LMS")</h1>
                </div>

                <div class="topbar-actions">
                    <button class="icon-button theme-toggle" type="button" id="themeToggle" title="Toggle dark mode" aria-label="Toggle dark mode">
                        <i data-lucide="moon"></i>
                    </button>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="user-pill"><i data-lucide="circle-user-round"></i>@User.Identity.Name</span>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button class="icon-button" type="submit" title="Sign out" aria-label="Sign out">
                                <i data-lucide="log-out"></i>
                            </button>
                        </form>
                    }
                    else
                    {
                        <a class="button button-ghost" asp-controller="Account" asp-action="Login">Login</a>
                        <a class="button" asp-controller="Account" asp-action="Register">Register</a>
                    }
                </div>
            </header>

            <partial name="_Alerts" />
            @RenderBody()
        </main>
    </div>

    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
