@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Borhanix</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="~/css/output.css" rel="stylesheet" asp-append-version="true" />
</head>

<body class="text-slate-700 dark:text-slate-200">

    <!-- Mobile Overlay -->
    <div id="sidebarOverlay"
         class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden">
    </div>

    <!-- Sidebar -->
    <aside id="sidebar"
           class="fixed left-0 top-0 z-50 h-screen w-64 border-slate-200  shadow-sm
        -translate-x-full lg:translate-x-0 transition-transform duration-300 flex flex-col bg-white dark:bg-dark-secondary">

        <!-- Brand -->
        <a asp-controller="Home"
           asp-action="Index"
           class="flex items-center justify-center h-24 border-b border-slate-200 dark:border-slate-600">

            <img src="~/images/borhanix-logo.png"
                 alt="Borhanix Logo"
                 class="h-11 w-auto" />

        </a>

        <!-- Navigation -->
        <nav class="flex-1 p-3 space-y-1 overflow-y-auto">

            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Dashboard" asp-action="Index"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-[#444] hover:bg-blue-600 hover:text-white transition
                    @(currentController == "Dashboard"
                           ? "bg-blue-600 text-white"
                          : "text-[#444] hover:bg-blue-600 hover:text-white dark:text-white")">
                    <i data-lucide="layout-dashboard"></i>
                    <span>Dashboard</span>
                </a>

                <a asp-controller="Profile" asp-action="Index"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-[#444] hover:bg-blue-600 hover:text-white transition

                    @(currentController == "Profile"
                                              ? "bg-blue-600 text-white"
                                            : "text-[#444] hover:bg-blue-600 hover:text-white dark:text-white")">
                    <i data-lucide="circle-user-round"></i>
                    <span>Profile</span>
                </a>

                <a asp-controller="Courses" asp-action="Index"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-[#444] hover:bg-blue-600 hover:text-white transition

                    @(currentController == "Courses"
                                             ? "bg-blue-600 text-white"
                                            : "text-[#444] hover:bg-blue-600 hover:text-white dark:text-white")">
                    <i data-lucide="book-open"></i>
                    <span>Courses</span>
                </a>

                <a asp-controller="Attendance" asp-action="Index"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-[#444] hover:bg-blue-600 hover:text-white transition
                    @(currentController == "Attendance"
                                                       ? "bg-blue-600 text-white"
                                                      : "text-[#444] hover:bg-blue-600 hover:text-white dark:text-white")">
                    <i data-lucide="qr-code"></i>
                    <span>Attendance</span>
                </a>

                <a asp-controller="AiAssistant" asp-action="Index"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-[#444]hover:bg-blue-600 hover:text-white transition

                    @(currentController == "AiAssistant"
                                             ? "bg-blue-600 text-white"
                                            : "text-[#444] hover:bg-blue-600 hover:text-white dark:text-white")">
                    <i data-lucide="sparkles"></i>
                    <span>AI Assistant</span>
                </a>

                @if (User.IsInRole(AppRoles.Instructor) || User.IsInRole(AppRoles.Admin))
                {
                    <a asp-controller="InstructorStudio" asp-action="Index"
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-[#444] hover:bg-blue-600 hover:text-white transition

                        @(currentController == "InstructorStudio"
                                                ? "bg-blue-600 text-white"
                                               : "text-[#444] hover:bg-blue-600 hover:text-white dark:text-white")">
                        <i data-lucide="presentation"></i>
                        <span>Instructor Studio</span>
                    </a>

                    <a asp-controller="Enrollments" asp-action="Pending"
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-[#444]hover:bg-blue-600 hover:text-white transition

                        @(currentController == "Enrollments"
                                               ? "bg-blue-600 text-white"
                                              : "text-[#444] hover:bg-blue-600 hover:text-white dark:text-white")">
                        <i data-lucide="user-check"></i>
                        <span>Approvals</span>
                    </a>
                }

                @if (User.IsInRole(AppRoles.Admin))
                {
                    <a asp-controller="Admin" asp-action="Index"
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-[#444] hover:bg-blue-600 hover:text-white transition

                        @(currentController == "Admin" && currentAction == "Index"
                                            ? "bg-blue-600 text-white"
                                           : "text-[#444] hover:bg-blue-600 hover:text-white dark:text-white")">
                        <i data-lucide="shield-check"></i>
                        <span>Admin</span>
                    </a>

                    <a asp-controller="Admin" asp-action="Users"
                       class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-[#444] hover:bg-blue-600 hover:text-white transition

                        @(currentController == "Admin" && currentAction == "Users"
                                             ? "bg-blue-600 text-white"
                                            : "text-[#444] hover:bg-blue-600 hover:text-white dark:text-white")">
                        <i data-lucide="users-round"></i>
                        <span>Users</span>
                    </a>
                }
            }
            else
            {
                <a asp-controller="Home" asp-action="Index"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-[#444] hover:bg-blue-600 hover:text-white transition 

                    @(currentController == "Home"
                                         ? "bg-blue-600 text-white"
                                        : "text-[#444] hover:bg-blue-600 hover:text-white dark:text-white")">
                    <i data-lucide="home"></i>
                    <span>Overview</span>
                </a>

                <a asp-controller="Account" asp-action="Login"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-[#444] hover:bg-blue-600 hover:text-white transition

                    @(currentController == "Account" && currentAction == "Login"
                                        ? "bg-blue-600 text-white"
                                       : "text-[#444] hover:bg-blue-600 hover:text-white dark:text-white")">
                    <i data-lucide="log-in"></i>
                    <span>Login</span>
                </a>

                <a asp-controller="Account" asp-action="Register"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-[#444]hover:bg-blue-600 hover:text-white transition 

                    @(currentController == "Account" && currentAction == "Register"
                                        ? "bg-blue-600 text-white"
                                       : "text-[#444] hover:bg-blue-600 hover:text-white dark:text-white")">
                    <i data-lucide="user-plus"></i>
                    <span>Register</span>
                </a>
            }
        </nav>
    </aside>

    <!-- Main -->
    <main class="lg:ml-64 min-h-screen">

        <!-- Header -->
        <header class="sticky top-0 z-30 h-16 border-b border-slate-200 dark:border-slate-600 shadow-sm flex items-center justify-between px-4 lg:px-6 bg-white dark:bg-dark-secondary">

            <div class="flex items-center gap-3">

                <button id="sidebarToggle"
                        class="lg:hidden p-2 rounded-lg hover:bg-slate-100">
                    <i data-lucide="menu"></i>
                </button>

                <div>
                    <p class="text-xs">
                        @DateTime.Now.ToString("dddd, MMM d")
                    </p>

                    <h1 class="font-bold">
                        @(ViewData["PageTitle"] ?? ViewData["Title"] ?? "Borhanix")
                    </h1>
                </div>
            </div>

            <div class="flex items-center gap-2">

                <!-- Theme toggle -->
                <button type="button"
                        id="themeToggle"
                        aria-label="Toggle theme"
                        class="rounded-md p-2 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary">
                    <i data-lucide="moon" id="themeIconMoon" class="size-5 sm:size-6"></i>
                    <i data-lucide="sun" id="themeIconSun" class="hidden size-5 sm:size-6"></i>
                </button>


                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="hidden md:flex items-center gap-2 px-3 py-2 rounded-full text-sm">
                        <i data-lucide="circle-user-round"></i>
                        @User.Identity.Name
                    </span>

                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit"
                                class="p-2 rounded-lg hover:bg-red-50 hover:text-red-600 transition">
                            <i data-lucide="log-out"></i>
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account"
                       asp-action="Login"
                       class="px-4 py-2 rounded-lg border border-slate-200 @(currentController == "Account" && currentAction == "Login"
                                                               ? "bg-blue-600 text-white"
                                                              : "text-[#444] hover:bg-blue-600 hover:text-white dark:text-white")">
                        Login
                    </a>

                    <a asp-controller="Account"
                       asp-action="Register"
                       class="px-4 py-2 rounded-lg
                        @(currentController == "Account" && currentAction == "Register"
                                                               ? "bg-blue-600 text-white"
                                                              : "text-[#444] hover:bg-blue-600 hover:text-white dark:text-white")">
                        Register
                    </a>
                }
            </div>
        </header>

        <!-- Content -->
        <div class="p-4 md:p-6">
            <partial name="_Alerts" />
            @RenderBody()
        </div>

    </main>

    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

        const sidebar = document.getElementById("sidebar");
        const overlay = document.getElementById("sidebarOverlay");
        const toggle = document.getElementById("sidebarToggle");

        toggle?.addEventListener("click", function () {
        sidebar.classList.toggle("-translate-x-full");
        overlay.classList.toggle("hidden");
        });

        overlay?.addEventListener("click", function () {
        sidebar.classList.add("-translate-x-full");
        overlay.classList.add("hidden");
        });

        lucide.createIcons();
        });
    </script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>