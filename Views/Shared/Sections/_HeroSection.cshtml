        <!-- Top: badge + headline + copy + CTAs -->
        <div class="flex flex-col items-center lg:items-start text-center lg:text-left mx-auto">
            <!-- Trustpilot badge -->
            <div class="flex items-center gap-2 mb-5 rounded-full dark:bg-white/5 px-3 py-1.5">
                <img src="~/images/home/trustpilot.png" alt="Trustpilot" class="h-6 w-auto object-contain" />
                <div class="flex items-center gap-1.5">
                    <span class="font-bold text-gray-800 dark:text-white text-sm">4.8</span>
                    <span class="text-gray-500 dark:text-white/50 text-sm">(3213 Reviews)</span>
                </div>
            </div>

            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-[#052c65] dark:text-white leading-tight mb-5 text-center lg:!text-left">
                Start Learning Today, Succeed Tomorrow
            </h1>

            <p class="text-base sm:text-lg text-[#475569] dark:text-white/70 leading-relaxed mb-8 max-w-2xl  text-center lg:text-left">
                Courses, modules, lessons, assignments, quizzes, grades, approval workflows, QR student cards,
                QR attendance, role dashboards, and a DeepSeek assistant through OpenRouter.
            </p>

            <div class="flex flex-col sm:flex-row items-center gap-3 mb-12 mt-6">
                <a asp-controller="Account" asp-action="Register"
                   class="inline-flex items-center justify-center gap-2 rounded-full bg-[#0d6efd] px-7 py-3 text-base font-semibold shadow-md transition-colors hover:bg-[#0a58ca] w-full sm:w-auto !text-white">
                    <i data-lucide="user-plus" class="size-5"></i>
                    Start Learning
                </a>
                <a asp-controller="Account" asp-action="Login"
                   class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-[#0d6efd] dark:border-[#8aa7ff] px-7 py-3 text-base font-semibold text-[#0d6efd] dark:text-primary transition-colors hover:bg-[#0d6efd] hover:!text-white dark:hover:bg-primary w-full sm:w-auto">
                    <i data-lucide="log-in" class="size-5"></i>
                    Login
                </a>
            </div>
        </div>

