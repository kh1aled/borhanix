        <div class="absolute top-[28%] left-[18%] w-2 h-2 bg-blue-300/40 dark:bg-white/20 rounded-full hidden md:block"></div>
        <div class="absolute top-[55%] left-[8%] w-4 h-0.5 bg-blue-300/50 dark:bg-white/20 rounded-full hidden md:block"></div>

