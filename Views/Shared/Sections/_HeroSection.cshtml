        <div class="absolute top-[40%] right-[6%] w-3 h-3 border-2 border-blue-300/50 dark:border-white/25 rotate-45 hidden md:block"></div>
        <div class="absolute top-[62%] right-[12%] w-3 h-3 border-2 border-blue-300/40 dark:border-white/15 rounded-full hidden md:block"></div>

        <div class="absolute top-[10%] right-[3%] text-blue-300/60 dark:text-white/25 text-2xl hidden lg:block">✦</div>
    </div>

