<section class="relative w-full overflow-hidden bg-[#ddeeff] py-16 sm:py-20 lg:py-24">

    <!-- Decorative background shapes -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-[15%] left-[10%] w-3 h-3 border-2 border-blue-300/50 rotate-45 hidden md:block"></div>
        <div class="absolute top-[28%] left-[18%] w-2 h-2 bg-blue-300/40 rounded-full hidden md:block"></div>
        <div class="absolute top-[55%] left-[8%] w-4 h-0.5 bg-blue-300/50 rounded-full hidden md:block"></div>

        <div class="absolute top-[18%] right-[10%] w-2 h-2 bg-blue-300/40 rounded-full hidden md:block"></div>
        <div class="absolute top-[40%] right-[6%] w-3 h-3 border-2 border-blue-300/50 rotate-45 hidden md:block"></div>
        <div class="absolute top-[62%] right-[12%] w-3 h-3 border-2 border-blue-300/40 rounded-full hidden md:block"></div>

        <div class="absolute top-[10%] right-[3%] text-blue-300/60 text-2xl hidden lg:block">✦</div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <!-- Top: badge + headline + copy + CTAs -->
        <div class="flex flex-col items-center text-center max-w-3xl mx-auto">
            <!-- Trustpilot badge -->
            <div class="flex items-center gap-2 mb-5">
                <img src="~/images/home/trustpilot.png" alt="Trustpilot" class="h-6 w-auto object-contain" />
                <div class="flex items-center gap-1.5">

                    <span class="font-bold text-gray-800 text-sm">4.8</span>
                    <span class="text-gray-500 text-sm">(3213 Reviews)</span>
                </div>
            </div>

            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-[#052c65] leading-tight mb-5">
                Start Learning Today, Succeed Tomorrow
            </h1>

            <p class="text-base sm:text-lg text-[#475569] leading-relaxed mb-8 max-w-2xl">
                Courses, modules, lessons, assignments, quizzes, grades, approval workflows, QR student cards,
                QR attendance, role dashboards, and a DeepSeek assistant through OpenRouter.
            </p>

            <div class="flex flex-col sm:flex-row items-center gap-3 mb-12 mt-6">
                <a asp-controller="Account" asp-action="Register"
                   class="inline-flex items-center justify-center gap-2 rounded-full bg-[#0d6efd] px-7 py-3 text-base font-semibold shadow-md transition-colors hover:bg-[#0a58ca] w-full sm:w-auto !text-white">
                    <i data-lucide="user-plus" class="size-5"></i>
                    Start Learning
                </a>
                <a asp-controller="Account" asp-action="Login"
                   class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-[#0d6efd] px-7 py-3 text-base font-semibold text-[#0d6efd] transition-colors hover:bg-[#0d6efd] hover:!text-white w-full sm:w-auto">
                    <i data-lucide="log-in" class="size-5"></i>
                    Login
                </a>
            </div>
        </div>

        <!-- Metrics strip -->
        <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-3 mb-16 text-[#052c65]">
            <span class="flex items-baseline gap-1.5">
                <strong class="text-2xl font-bold">@ViewBag.CourseCount</strong>
                <span class="text-sm text-[#475569]">Courses</span>
            </span>
            <span class="hidden sm:block w-px h-6 bg-[#cfe2ff]"></span>
            <span class="flex items-baseline gap-1.5">
                <strong class="text-2xl font-bold">@ViewBag.StudentCount</strong>
                <span class="text-sm text-[#475569]">Users</span>
            </span>
            <span class="hidden sm:block w-px h-6 bg-[#cfe2ff]"></span>
            <span class="flex items-baseline gap-1.5">
                <strong class="text-2xl font-bold">3</strong>
                <span class="text-sm text-[#475569]">Roles</span>
            </span>
        </div>

        <!-- Feature highlights -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl mx-auto">
            <div class="flex flex-col items-center text-center gap-2 rounded-2xl bg-white/70 backdrop-blur-sm p-5 shadow-sm">
                <i data-lucide="qr-code" class="size-6 text-[#0d6efd]"></i>
                <strong class="text-[#052c65] text-sm">QR ID</strong>
                <small class="text-[#64748b] text-xs">Attendance + card</small>
            </div>
            <div class="flex flex-col items-center text-center gap-2 rounded-2xl bg-white/70 backdrop-blur-sm p-5 shadow-sm">
                <i data-lucide="brain-circuit" class="size-6 text-[#0d6efd]"></i>
                <strong class="text-[#052c65] text-sm">AI</strong>
                <small class="text-[#64748b] text-xs">DeepSeek assistant</small>
            </div>
            <div class="flex flex-col items-center text-center gap-2 rounded-2xl bg-white/70 backdrop-blur-sm p-5 shadow-sm">
                <i data-lucide="shield-check" class="size-6 text-[#0d6efd]"></i>
                <strong class="text-[#052c65] text-sm">Identity</strong>
                <small class="text-[#64748b] text-xs">Role security</small>
            </div>
            <div class="flex flex-col items-center text-center gap-2 rounded-2xl bg-white/70 backdrop-blur-sm p-5 shadow-sm">
                <i data-lucide="graduation-cap" class="size-6 text-[#0d6efd]"></i>
                <strong class="text-[#052c65] text-sm">LMS</strong>
                <small class="text-[#64748b] text-xs">Full course flow</small>
            </div>
        </div>
    </div>

    <!-- Side illustrations (desktop only, sit below the fold edge) -->
    <div class="absolute left-0 bottom-0 w-[220px] xl:w-[300px] pointer-events-none select-none hidden lg:block">
        <img src="~/images/home/banner-catalog-1.png" alt="" class="object-contain object-bottom w-full h-auto opacity-90" />
    </div>
    <div class="absolute right-0 bottom-0 w-[200px] xl:w-[280px] pointer-events-none select-none hidden lg:block">
        <img src="~/images/home/banner-catalog-2.png" alt="" class="object-contain object-bottom w-full h-auto opacity-90" />
    </div>
</section>