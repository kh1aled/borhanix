<section class="relative overflow-hidden bg-[#0068D9] dark:bg-gradient-to-br dark:from-[#0d6efd] dark:via-[#0b5ed7] dark:to-[#084298] dark:from-slate-950 dark:via-slate-900 dark:to-slate-950">

    <!-- Background Pattern -->
    <div class="absolute inset-0 bg-[url('/images/shared/subscribe-bg.png')] bg-cover bg-center opacity-15 dark:opacity-5"></div>

    <!-- Decorative Shapes -->
    <div class="absolute -left-16 top-12 w-72 h-12 rounded-full bg-white/10 dark:bg-blue-500/10 blur-sm"></div>
    <div class="absolute -left-10 top-32 w-56 h-12 rounded-full bg-white/10 dark:bg-blue-400/10 blur-sm"></div>
    <div class="absolute -left-6 top-52 w-40 h-12 rounded-full bg-white/10 dark:bg-blue-300/10 blur-sm"></div>

    <div class="absolute right-[-70px] top-20 w-48 h-48 rounded-full bg-white/5 dark:bg-blue-500/10 blur-3xl"></div>
    <div class="absolute left-1/2 -translate-x-1/2 bottom-[-100px] w-80 h-80 rounded-full bg-cyan-400/10 blur-3xl"></div>

    <div class="relative max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 py-20">

        <!-- Heading -->
        <div class="max-w-3xl mx-auto text-center mb-12">

            <h2 class="text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-4">
                Join Thousands of Happy Students
            </h2>

            <p class="text-lg text-blue-100 dark:text-slate-300 leading-relaxed">
                Subscribe to our newsletter and receive the latest courses,
                learning tips, platform updates, and exclusive offers.
            </p>

        </div>

        <!-- Subscribe Form -->
        <form asp-controller="Newsletter"
              asp-action="Subscribe"
              method="post"
              class="max-w-3xl mx-auto">

            <div class="flex flex-col sm:flex-row gap-4 sm:gap-2 rounded-2xl bg-white/95 dark:bg-slate-900/80 backdrop-blur-xl border border-white/20 dark:border-blue-500/20 p-3 shadow-2xl">

                <input
                    type="email"
                    name="email"
                    required
                    placeholder="Enter your email address..."
                    class="flex-1 bg-transparent border-none outline-none focus:ring-0 text-slate-700 dark:text-slate-200 placeholder:text-slate-400 dark:placeholder:text-slate-500 px-4 py-3 text-base" />

                <button
                    type="submit"
                    class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-blue-600 to-blue-500 hover:from-blue-700 hover:to-blue-600 text-white font-semibold px-8 py-3 transition-all duration-300 shadow-lg hover:shadow-blue-500/30">

                    Get Started

                    <i data-lucide="arrow-right" class="w-5 h-5"></i>

                </button>

            </div>

        </form>

    </div>

</section>