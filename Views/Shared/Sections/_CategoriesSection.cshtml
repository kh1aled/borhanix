<section class="section bg-white dark:bg-third">
    <div class="container mx-auto px-6 md:px-[60px] py-20">

        @* Heading *@
        <div class="flex flex-col items-center text-center mb-14">
            <span class="text-xs font-semibold tracking-[0.2em] uppercase text-[#0d6efd] mb-3">Categories</span>
            <h2 class="text-3xl md:text-4xl font-bold text-[#052c65] dark:text-white mb-3">Discover Categories</h2>
            <p class="text-muted text-base dark:!text-gray-500 max-w-md">Browse a Wide Range of Subjects to Start Learning What You Love</p>
        </div>

        @{
            var categories = new[]
            {
                new { Title = "Web Development", Count = 12, Icon = "code-2" },
                new { Title = "UI/UX Design", Count = 45, Icon = "pen-tool" },
                new { Title = "Mobile Development", Count = 23, Icon = "smartphone" },
                new { Title = "Digital Marketing", Count = 56, Icon = "megaphone" },
                new { Title = "Entrepreneurship", Count = 87, Icon = "briefcase" },
                new { Title = "Personal Finance", Count = 35, Icon = "wallet" },
                new { Title = "IT & Software", Count = 33, Icon = "terminal" },
                new { Title = "Health & Fitness", Count = 37, Icon = "heart-pulse" },
            };
        }

        @* Grid *@
        <div class="w-full grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
            @for (var i = 0; i < categories.Length; i++)
            {
                var cat = categories[i];
                <a href="#"
                   style="animation-delay:@(i * 60)ms"
                   class="group relative flex flex-col p-6 rounded-2xl bg-white dark:bg-gray-800
                    border border-gray-100 dark:border-gray-700/60 overflow-hidden
                    transition-all duration-300 ease-out
                    hover:-translate-y-1.5 hover:border-transparent shadow-sm
                    focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#0d6efd]
                    animate-[fadeInUp_0.5s_ease-out_backwards]">

                    @* Top accent line that grows in on hover *@
                    <span class="absolute top-0 left-0 h-[3px] w-0 bg-[#0d6efd] transition-all duration-300 ease-out group-hover:w-full"></span>

                    @* Icon square *@
                    <div class="w-14 h-14 rounded-xl bg-[#f0f4fa] dark:bg-gray-700
                        flex items-center justify-center text-[#0d6efd] dark:text-[#5b9bff]
                        transition-colors duration-300
                        group-hover:bg-[#0d6efd] group-hover:text-white">
                        <i data-lucide="@cat.Icon" class="w-7 h-7"></i>
                    </div>

                    @* Title *@
                    <h3 class="mt-5 text-[#1e293b] dark:text-white text-lg font-semibold leading-snug
                        transition-colors duration-300 group-hover:text-[#0d6efd] dark:group-hover:text-[#5b9bff]">
                        @cat.Title
                    </h3>

                    @* Footer row: count pill + arrow *@
                    <div class="mt-4 flex items-center justify-between">
                        <span class="inline-flex items-center rounded-full bg-[#eaf2ff] dark:bg-gray-700
                            px-3 py-1 text-xs font-medium text-[#0d6efd] dark:text-[#5b9bff]">
                            @cat.Count Courses
                        </span>
                        <span class="flex items-center justify-center w-8 h-8 rounded-full text-[#0d6efd]
                            opacity-0 -translate-x-2 transition-all duration-300 ease-out
                            group-hover:opacity-100 group-hover:translate-x-0">
                            <i data-lucide="arrow-right" class="w-4 h-4"></i>
                        </span>
                    </div>
                </a>
            }
        </div>

    </div>
</section>

<style>
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (prefers-reduced-motion: reduce) {
        .group {
            animation: none !important;
        }
    }
</style>
