@model QuizTakeViewModel
@{
    ViewData["Title"] = Model.Quiz.Title;
    ViewData["PageTitle"] = "Quiz";

    var orderedQuestions = Model.Quiz.Questions.OrderBy(x => x.SortOrder).ToList();
    var questionCount = orderedQuestions.Count;
}

<form class="quiz-form flex flex-col gap-6" asp-action="Submit" method="post">
    <input type="hidden" asp-for="QuizId" />

    @* ================= HERO ================= *@
    <section class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-violet-600 via-violet-600 to-primary dark:from-slate-900 dark:via-slate-900 dark:to-violet-900/30 p-8 md:p-10 shadow-lg shadow-violet-600/10">
        <div class="pointer-events-none absolute -right-16 -top-16 w-72 h-72 bg-white/10 rounded-full blur-3xl"></div>
        <div class="pointer-events-none absolute -left-10 bottom-0 w-56 h-56 bg-white/5 rounded-full blur-3xl"></div>

        <div class="relative z-10 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
            <div class="flex flex-col gap-4">
                <span class="inline-flex items-center gap-1.5 w-fit rounded-full bg-white/15 backdrop-blur px-3 py-1.5 text-sm font-medium text-white ring-1 ring-white/25">
                    <i data-lucide="circle-help" class="w-4 h-4"></i>
                    @Model.Quiz.Course.Code
                </span>

                <h1 class="text-2xl md:text-3xl font-bold text-white tracking-tight">@Model.Quiz.Title</h1>
                <p class="text-white/80 max-w-2xl leading-relaxed">@Model.Quiz.Summary</p>

                <div class="flex flex-wrap gap-x-8 gap-y-2 pt-1 text-sm text-white/90">
                    <div class="flex items-center gap-2">
                        <i data-lucide="list-checks" class="w-4 h-4"></i>
                        <span>@questionCount question@(questionCount == 1 ? "" : "s")</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <i data-lucide="timer" class="w-4 h-4"></i>
                        <span>@Model.Quiz.TimeLimitMinutes minutes</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <i data-lucide="star" class="w-4 h-4"></i>
                        <span>@Model.Quiz.MaxPoints points</span>
                    </div>
                </div>
            </div>

            @if (User.IsInRole(AppRoles.Instructor) || User.IsInRole(AppRoles.Admin))
            {
                <a class="inline-flex items-center justify-center gap-2 rounded-xl bg-white/15 backdrop-blur text-white font-semibold text-sm px-5 py-2.5 ring-1 ring-white/25 hover:bg-white/25 transition-all duration-300"
                   asp-action="Attempts" asp-route-id="@Model.Quiz.Id">
                    <i data-lucide="bar-chart-3" class="w-4 h-4"></i>
                    Attempts
                </a>
            }
        </div>
    </section>

    @* ================= PROGRESS BAR (visual only, updates as options are picked) ================= *@
    @if (User.IsInRole(AppRoles.Student))
    {
        <div class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-5 py-4 shadow-sm flex items-center gap-4">
            <span class="flex-shrink-0 inline-flex items-center gap-2 text-sm font-medium text-slate-600 dark:text-slate-300">
                <i data-lucide="pen-line" class="w-4 h-4 text-primary"></i>
                <span id="quiz-progress-label">0 / @questionCount answered</span>
            </span>
            <div class="flex-1 h-2 rounded-full bg-slate-100 dark:bg-slate-800 overflow-hidden">
                <div id="quiz-progress-bar" class="h-full bg-primary rounded-full transition-all duration-300" style="width: 0%"></div>
            </div>
        </div>
    }

    @* ================= QUESTION LIST ================= *@
    <section class="question-list flex flex-col gap-5">
        @{ var questionIndex = 0; }
        @foreach (var question in orderedQuestions)
        {
            questionIndex++;
            <article class="question-card rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 md:p-7 shadow-sm hover:shadow-md transition-all duration-300">
                <div class="flex items-start gap-3 mb-5">
                    <span class="flex-shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-lg bg-primary/10 text-primary font-semibold text-sm">
                        @questionIndex
                    </span>
                    <h3 class="text-base md:text-lg font-semibold text-slate-900 dark:text-white leading-snug pt-0.5">@question.Prompt</h3>
                </div>

                <div class="option-list flex flex-col gap-2.5 pl-11">
                    @foreach (var option in question.Options)
                    {
                        <label class="option-row group flex items-center gap-3 rounded-xl border border-slate-200 dark:border-slate-700 px-4 py-3 cursor-pointer has-[:checked]:border-primary has-[:checked]:bg-primary/5 hover:border-primary/60 transition-all duration-300">
                            <input type="radio" name="SelectedOptions[@question.Id]" value="@option.Id"
                                   class="quiz-option w-4 h-4 accent-primary flex-shrink-0" />
                            <span class="text-sm text-slate-700 dark:text-slate-200 group-has-[:checked]:text-primary group-has-[:checked]:font-medium">@option.Text</span>
                        </label>
                    }
                </div>
            </article>
        }
    </section>

    @* ================= SUBMIT ================= *@
    @if (User.IsInRole(AppRoles.Student))
    {
        <div class="sticky bottom-4 z-10 flex justify-end">
            <button class="inline-flex items-center gap-2 rounded-xl bg-primary text-white font-semibold text-sm px-6 py-3.5 shadow-lg shadow-primary/25 hover:shadow-xl hover:bg-primary/90 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
                    type="submit">
                <i data-lucide="check-circle-2" class="w-4.5 h-4.5"></i>
                Submit quiz
            </button>
        </div>
    }
</form>

@* ================= VISUAL-ONLY PROGRESS SCRIPT (no submission logic touched) ================= *@
@if (User.IsInRole(AppRoles.Student))
{
    <script>
        (function () {
            var options = document.querySelectorAll('.quiz-option');
            var groups = new Set();
            options.forEach(function (opt) { groups.add(opt.name); });
            var total = groups.size;

            function updateProgress() {
                var answered = new Set();
                options.forEach(function (opt) {
                    if (opt.checked) answered.add(opt.name);
                });
                var pct = total > 0 ? Math.round((answered.size / total) * 100) : 0;
                var bar = document.getElementById('quiz-progress-bar');
                var label = document.getElementById('quiz-progress-label');
                if (bar) bar.style.width = pct + '%';
                if (label) label.textContent = answered.size + ' / ' + total + ' answered';
            }

            options.forEach(function (opt) {
                opt.addEventListener('change', updateProgress);
            });

            updateProgress();
        })();
    </script>
}
