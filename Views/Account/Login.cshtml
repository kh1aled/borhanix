@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    ViewData["PageTitle"] = "Welcome back";
    Layout = "_AuthLayout";
}

<div class="min-h-screen w-full flex items-center justify-center relative overflow-hidden login-bg-cover">

    <div class="relative z-10 bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 px-10 py-10">

        <h1 class="text-primary text-[1.5rem] text-center font-bold mb-2">LOGIN</h1>
        <h2 class="text-lg font-medium text-center">Welcome Back!</h2>
        <p class="font-medium mb-3 text-base text-center">Ready to Learn and Grow?</p>

        <form asp-action="Login" method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-3 text-center"></div>

            <div class="relative mb-5">
                <input asp-for="Email"
                       id="emailInput"
                       type="email"
                       autocomplete="email"
                       placeholder="Email"
                       class="w-full bg-[#f0f2fa] rounded-lg px-4 py-3 pr-11 text-sm text-gray-700 placeholder-gray-400 border-0 outline-none focus:ring-2 focus:ring-[#3b4db8] transition" />
                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                    </svg>
                </span>
                <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div class="relative mb-6">
                <input asp-for="Password"
                       type="password"
                       id="passwordInput"
                       autocomplete="current-password"
                       placeholder="Password"
                       class="w-full bg-[#f0f2fa] rounded-lg px-4 py-3 pr-11 text-sm text-gray-700 placeholder-gray-400 border-0 outline-none focus:ring-2 focus:ring-[#3b4db8] transition" />
                <button type="button" onclick="togglePassword()"
                        class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition">
                    <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                </button>
                <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <button type="submit"
                    class="w-full bg-primary hover:bg-primary/80 cursor-pointer text-white font-semibold py-3 rounded-xl text-base tracking-wide transition-colors duration-200 shadow-md">
                Login
            </button>
        </form>

        <div class="mt-6">
            <div class="flex items-center gap-2 mb-3">
                <div class="flex-1 h-px bg-gray-200"></div>
                <span class="text-xs text-gray-400 font-medium whitespace-nowrap">Quick access — Dev accounts</span>
                <div class="flex-1 h-px bg-gray-200"></div>
            </div>

            <div class="grid grid-cols-3 gap-2">

                <button type="button"
                        onclick="fillCredentials(this,'admin@depi.edu','Admin@12345')"
                        class="seed-card group flex flex-col items-center gap-1.5 rounded-xl border border-gray-100 bg-gray-50 px-2 py-3 text-center hover:border-red-300 hover:bg-red-50 transition-all duration-200 cursor-pointer">
                    <span class="flex h-8 w-8 items-center justify-center rounded-full bg-red-100 group-hover:bg-red-200 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                        </svg>
                    </span>
                    <span class="text-[11px] font-semibold text-gray-700 group-hover:text-red-700 leading-tight">Admin</span>
                    <span class="text-[9px] text-gray-400 group-hover:text-red-400 leading-tight">Click to fill</span>
                </button>

                <button type="button"
                        onclick="fillCredentials(this,'instructor@depi.edu','Instructor@12345')"
                        class="seed-card group flex flex-col items-center gap-1.5 rounded-xl border border-gray-100 bg-gray-50 px-2 py-3 text-center hover:border-amber-300 hover:bg-amber-50 transition-all duration-200 cursor-pointer">
                    <span class="flex h-8 w-8 items-center justify-center rounded-full bg-amber-100 group-hover:bg-amber-200 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-1.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
                        </svg>
                    </span>
                    <span class="text-[11px] font-semibold text-gray-700 group-hover:text-amber-700 leading-tight">Instructor</span>
                    <span class="text-[9px] text-gray-400 group-hover:text-amber-400 leading-tight">Click to fill</span>
                </button>

                <button type="button"
                        onclick="fillCredentials(this,'student@depi.edu','Student@12345')"
                        class="seed-card group flex flex-col items-center gap-1.5 rounded-xl border border-gray-100 bg-gray-50 px-2 py-3 text-center hover:border-blue-300 hover:bg-blue-50 transition-all duration-200 cursor-pointer">
                    <span class="flex h-8 w-8 items-center justify-center rounded-full bg-blue-100 group-hover:bg-blue-200 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                        </svg>
                    </span>
                    <span class="text-[11px] font-semibold text-gray-700 group-hover:text-blue-700 leading-tight">Student</span>
                    <span class="text-[9px] text-gray-400 group-hover:text-blue-400 leading-tight">Click to fill</span>
                </button>

            </div>
        </div>

        <div class="flex gap-4 justify-center items-center mt-6 mb-1">
            <img class="w-32" alt="borhanix logo" src="~/images/borhanix-logo.png">
        </div>

        <div class="text-center text-sm mt-4 text-gray-400">
            Don't have an account?
            <a class="cursor-pointer text-gray-600 dark:text-white hover:underline" asp-controller="Account" asp-action="Register">Sign up</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword() {
            const input = document.getElementById('passwordInput');
            input.type = input.type === 'password' ? 'text' : 'password';
        }

        function fillCredentials(btn, email, password) {
            const emailInput = document.getElementById('emailInput');
            const passInput  = document.getElementById('passwordInput');

            document.querySelectorAll('.seed-card').forEach(c => {
                c.classList.remove('ring-2', 'ring-primary', 'border-primary');
            });

            btn.classList.add('ring-2', 'ring-primary', 'border-primary');

            emailInput.value = '';
            passInput.value  = '';

            typeValue(emailInput, email, () => {
                typeValue(passInput, password);
            });
        }

        function typeValue(input, text, callback) {
            let i = 0;
            input.focus();
            const interval = setInterval(() => {
                input.value += text[i];
                i++;
                if (i >= text.length) {
                    clearInterval(interval);
                    if (callback) callback();
                }
            }, 28);
        }
    </script>
}
