@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    ViewData["PageTitle"] = "Welcome back";
}

<section class="auth-layout">
    <form class="auth-card" asp-action="Login" method="post">
        <input type="hidden" asp-for="ReturnUrl" />
        <div class="form-heading">
            <span class="badge"><i data-lucide="lock-keyhole"></i> Secure access</span>
            <h2>Sign in</h2>
        </div>
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <label asp-for="Email"></label>
        <input asp-for="Email" autocomplete="email" placeholder="student@depi.edu" />
        <span asp-validation-for="Email"></span>

        <label asp-for="Password"></label>
        <input asp-for="Password" autocomplete="current-password" placeholder="Password" />
        <span asp-validation-for="Password"></span>

        <label class="check-line">
            <input asp-for="RememberMe" />
            <span>Remember me</span>
        </label>

        <button class="button" type="submit"><i data-lucide="log-in"></i>Login</button>

        <div class="demo-logins">
            <strong>Seed accounts</strong>
            <span>admin@depi.edu / Admin@12345</span>
            <span>instructor@depi.edu / Instructor@12345</span>
            <span>student@depi.edu / Student@12345</span>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
