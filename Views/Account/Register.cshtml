@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
    ViewData["PageTitle"] = "Create account";
    Layout = "_AuthLayout";
}

<div class="min-h-screen w-full flex items-center justify-center relative overflow-hidden login-bg-cover py-10">

    <div class="relative z-10 bg-white dark:bg-gray-800 dark:border dark:border-gray-600 rounded-2xl shadow-2xl w-full max-w-xl mx-4 px-10 py-10">

        <h1 class="text-primary text-[1.5rem] text-center font-bold mb-2">REGISTER</h1>
        <h2 class="text-lg font-medium text-center text-slate-800 dark:text-white">Join Borhanix!</h2>
        <p class="font-medium mb-6 text-base text-center text-slate-600 dark:text-slate-300">Start your learning journey today.</p>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-red-500 dark:text-red-400 text-sm mb-4 text-center bg-red-50 dark:bg-red-500/10 rounded-lg py-2 px-3"></div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">

                <div class="relative">
                    <label asp-for="FullName" class="block text-xs font-semibold text-gray-500 dark:text-slate-400 mb-1 ml-1">Full Name</label>
                    <div class="relative">
                        <input asp-for="FullName"
                               placeholder="Full name"
                               class="w-full bg-[#f0f2fa] dark:bg-gray-700 rounded-lg px-4 py-3 pr-11 text-sm text-gray-700 dark:text-slate-200 placeholder-gray-400 dark:placeholder-slate-500 border-0 dark:border dark:border-gray-600 outline-none focus:outline-none focus:border-primary transition" />
                        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 dark:text-slate-500">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                            </svg>
                        </span>
                    </div>
                    <span asp-validation-for="FullName" class="text-red-500 dark:text-red-400 text-xs mt-1 block"></span>
                </div>

                <div class="relative">
                    <label asp-for="Email" class="block text-xs font-semibold text-gray-500 dark:text-slate-400 mb-1 ml-1">Email</label>
                    <div class="relative">
                        <input asp-for="Email"
                               placeholder="name@depi.edu"
                               class="w-full bg-[#f0f2fa] dark:bg-gray-700 rounded-lg px-4 py-3 pr-11 text-sm text-gray-700 dark:text-slate-200 placeholder-gray-400 dark:placeholder-slate-500 border-0 dark:border dark:border-gray-600 outline-none focus:outline-none focus:border-primary transition" />
                        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 dark:text-slate-500">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                            </svg>
                        </span>
                    </div>
                    <span asp-validation-for="Email" class="text-red-500 dark:text-red-400 text-xs mt-1 block"></span>
                </div>

                <div class="relative">
                    <label asp-for="Password" class="block text-xs font-semibold text-gray-500 dark:text-slate-400 mb-1 ml-1">Password</label>
                    <div class="relative">
                        <input asp-for="Password"
                               type="password"
                               id="passwordInput"
                               placeholder="At least 8 characters"
                               class="w-full bg-[#f0f2fa] dark:bg-gray-700 rounded-lg px-4 py-3 pr-11 text-sm text-gray-700 dark:text-slate-200 placeholder-gray-400 dark:placeholder-slate-500 border-0 dark:border dark:border-gray-600 outline-none focus:outline-none focus:border-primary transition" />
                        <button type="button" onclick="togglePass('passwordInput')"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 dark:text-slate-500 hover:text-gray-600 dark:hover:text-slate-300 transition">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-red-500 dark:text-red-400 text-xs mt-1 block"></span>
                </div>

                <div class="relative">
                    <label asp-for="ConfirmPassword" class="block text-xs font-semibold text-gray-500 dark:text-slate-400 mb-1 ml-1">Confirm Password</label>
                    <div class="relative">
                        <input asp-for="ConfirmPassword"
                               type="password"
                               id="confirmPasswordInput"
                               placeholder="Repeat password"
                               class="w-full bg-[#f0f2fa] dark:bg-gray-700 rounded-lg px-4 py-3 pr-11 text-sm text-gray-700 dark:text-slate-200 placeholder-gray-400 dark:placeholder-slate-500 border-0 dark:border dark:border-gray-600 outline-none focus:outline-none focus:border-primary transition" />
                        <button type="button" onclick="togglePass('confirmPasswordInput')"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 dark:text-slate-500 hover:text-gray-600 dark:hover:text-slate-300 transition">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-red-500 dark:text-red-400 text-xs mt-1 block"></span>
                </div>

                <div class="relative">
                    <label asp-for="Role" class="block text-xs font-semibold text-gray-500 dark:text-slate-400 mb-1 ml-1">Role</label>
                    <div class="relative">
                        <select asp-for="Role"
                                class="w-full bg-[#f0f2fa] dark:bg-gray-700 rounded-lg px-4 py-3 pr-11 text-sm text-gray-700 dark:text-slate-200 border-0 dark:border dark:border-gray-600 outline-none focus:outline-none focus:border-primary transition appearance-none cursor-pointer">
                            <option value="@AppRoles.Student">Student</option>
                            <option value="@AppRoles.Instructor">Instructor</option>
                        </select>
                        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 dark:text-slate-500 pointer-events-none">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                            </svg>
                        </span>
                    </div>
                    <span asp-validation-for="Role" class="text-red-500 dark:text-red-400 text-xs mt-1 block"></span>
                </div>

                <div class="relative">
                    <label asp-for="ProgramOrDepartment" class="block text-xs font-semibold text-gray-500 dark:text-slate-400 mb-1 ml-1">Program / Department</label>
                    <div class="relative">
                        <input asp-for="ProgramOrDepartment"
                               placeholder="Full Stack .NET"
                               class="w-full bg-[#f0f2fa] dark:bg-gray-700 rounded-lg px-4 py-3 pr-11 text-sm text-gray-700 dark:text-slate-200 placeholder-gray-400 dark:placeholder-slate-500 border-0 dark:border dark:border-gray-600 outline-none focus:outline-none focus:border-primary transition" />
                        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 dark:text-slate-500">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-1.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
                            </svg>
                        </span>
                    </div>
                    <span asp-validation-for="ProgramOrDepartment" class="text-red-500 dark:text-red-400 text-xs mt-1 block"></span>
                </div>

            </div>

            <button type="submit"
                    class="w-full bg-primary hover:bg-primary/80 cursor-pointer text-white font-semibold py-3 rounded-xl text-base tracking-wide transition-colors duration-200 shadow-md dark:shadow-primary/20 mt-2">
                Create Account
            </button>
        </form>

        <div class="flex gap-4 justify-center items-center mt-6 mb-1">
            <img class="w-32" alt="borhanix logo" src="~/images/borhanix-logo.png">
        </div>

        <div class="text-center text-sm mt-4 text-gray-400 dark:text-slate-500">
            Already have an account?
            <a class="cursor-pointer text-gray-600 dark:text-white hover:underline" asp-controller="Account" asp-action="Login">Sign in</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePass(id) {
            const input = document.getElementById(id);
            input.type = input.type === 'password' ? 'text' : 'password';
        }
    </script>
}
