@model ChangeEmailViewModel

<form asp-action="UpdateEmail" method="post"
      class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
    @Html.AntiForgeryToken()

    <!-- Section header -->
    <div class="flex items-center gap-3 px-6 py-5 border-b border-gray-100 dark:border-gray-700">
        <div class="flex items-center justify-center w-9 h-9 rounded-xl bg-primary/10 dark:bg-primary/20">
            <i data-lucide="mail" class="w-5 h-5 text-primary"></i>
        </div>
        <div>
            <h2 class="text-base font-semibold text-gray-900 dark:text-white">Update Email</h2>
            <p class="text-xs text-gray-500 dark:text-gray-400">You'll need to verify the new address after changing it</p>
        </div>
    </div>

    <div class="px-6 py-6 space-y-4">

        <!-- Current email (read-only, for reference) -->
        <div class="space-y-1.5">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Current Email</label>
            <div class="w-full px-3.5 py-2.5 rounded-xl border border-gray-100 dark:border-gray-700
                bg-gray-50 dark:bg-gray-700/50 text-sm text-gray-500 dark:text-gray-400 select-none">
                @User.Identity.Name
            </div>
        </div>

        <!-- New email + Confirm email side by side -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

            <!-- New Email -->
            <div class="space-y-1.5">
                <label for="NewEmail"
                       class="block text-sm font-medium text-gray-700 dark:text-gray-300">New Email</label>
                <input type="email" id="NewEmail" name="NewEmail"
                       placeholder="Enter new email address"
                       class="w-full px-3.5 py-2.5 rounded-xl border border-gray-200 dark:border-gray-600
                bg-white dark:bg-gray-700 text-gray-900 dark:text-white
                placeholder-gray-400 dark:placeholder-gray-500 text-sm
                focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-shadow" />
                <span class="text-xs text-red-500" data-valmsg-for="NewEmail"></span>
            </div>

            <!-- Confirm Email -->
            <div class="space-y-1.5">
                <label for="ConfirmEmail"
                       class="block text-sm font-medium text-gray-700 dark:text-gray-300">Confirm Email</label>
                <input type="email" id="ConfirmEmail" name="ConfirmEmail"
                       placeholder="Re-enter new email address"
                       class="w-full px-3.5 py-2.5 rounded-xl border border-gray-200 dark:border-gray-600
                bg-white dark:bg-gray-700 text-gray-900 dark:text-white
                placeholder-gray-400 dark:placeholder-gray-500 text-sm
                focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-shadow" />
                <span class="text-xs text-red-500" data-valmsg-for="ConfirmEmail"></span>
            </div>

        </div>

        <!-- Info note -->
        <div class="flex items-start gap-2 p-3 rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-100 dark:border-amber-800/40">
            <i data-lucide="info" class="w-4 h-4 text-amber-500 dark:text-amber-400 shrink-0 mt-0.5"></i>
            <p class="text-xs text-amber-700 dark:text-amber-400">
                After changing your email, you will need to verify the new address before it becomes active.
            </p>
        </div>

    </div>

    <!-- Form footer -->
    <div class="flex items-center justify-end px-6 py-4
        bg-gray-50 dark:bg-gray-800/50 rounded-b-2xl border-t border-gray-100 dark:border-gray-700">
        <button type="submit"
                class="flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-medium
            bg-primary hover:bg-primary/90 active:bg-primary/80 text-white shadow-sm
            transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
            <i data-lucide="mail-check" class="w-4 h-4"></i>
            Update Email
        </button>
    </div>

</form>
<!-- END Update Email Form -->