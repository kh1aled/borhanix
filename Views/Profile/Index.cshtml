@model ProfileViewModel
@{
    ViewData["Title"] = "Profile";
    ViewData["PageTitle"] = "My profile";
}

<section class="profile-layout">
    <aside class="profile-card">
        <div class="profile-photo" style="--avatar:@Model.AvatarColor">
            @if (!string.IsNullOrWhiteSpace(Model.ProfilePhotoUrl))
            {
                <img src="@Model.ProfilePhotoUrl" alt="@Model.FullName" />
            }
            else
            {
                <span>@Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(x => x[0]).Take(2).Aggregate("", (a, b) => a + b)</span>
            }
        </div>
        <h2>@Model.FullName</h2>
        <p>@Model.ProgramOrDepartment</p>
        <span class="status-pill">@(Model.IsApproved ? "Approved" : "Pending approval")</span>
        @if (Model.IsStudent)
        {
            <a class="button button-ghost" asp-controller="Attendance" asp-action="StudentCard"><i data-lucide="id-card"></i>Student card</a>
        }
    </aside>

    <form class="editor-panel" asp-action="Update" method="post" enctype="multipart/form-data">
        <div class="form-heading">
            <span class="badge"><i data-lucide="circle-user-round"></i> Profile</span>
            <h2>Edit information</h2>
        </div>

        <div class="form-grid">
            <div>
                <label asp-for="FullName"></label>
                <input asp-for="FullName" />
                <span asp-validation-for="FullName"></span>
            </div>
            <div>
                <label asp-for="PhoneNumber"></label>
                <input asp-for="PhoneNumber" />
                <span asp-validation-for="PhoneNumber"></span>
            </div>
            <div>
                <label asp-for="ProgramOrDepartment">Program / Department</label>
                <input asp-for="ProgramOrDepartment" />
            </div>
            <div>
                <label asp-for="LevelOrTitle">Level / Title</label>
                <input asp-for="LevelOrTitle" />
            </div>
            <div>
                <label asp-for="EmergencyContactOrOfficeHours">Emergency contact / Office hours</label>
                <input asp-for="EmergencyContactOrOfficeHours" />
            </div>
            <div>
                <label asp-for="AvatarColor"></label>
                <input asp-for="AvatarColor" type="color" />
            </div>
        </div>

        <label asp-for="Bio"></label>
        <textarea asp-for="Bio" rows="5"></textarea>

        <label asp-for="ProfilePhoto">Profile photo</label>
        <input asp-for="ProfilePhoto" type="file" accept=".jpg,.jpeg,.png,.webp" />
        <span asp-validation-for="ProfilePhoto"></span>

        <button class="button" type="submit"><i data-lucide="save"></i>Save profile</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
