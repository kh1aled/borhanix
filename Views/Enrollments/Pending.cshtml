@model IReadOnlyCollection<Enrollment>
@{
    ViewData["Title"] = "Approvals";
    ViewData["PageTitle"] = "Enrollment approvals";
}

@* Header *@
<div class="flex items-start justify-between gap-4 mb-6">
    <div>
        <div class="flex items-center gap-1.5 text-[11px] font-semibold tracking-widest uppercase text-primary mb-1.5">
            <i data-lucide="user-check" class="w-3.5 h-3.5"></i>
            Approval queue
        </div>
        <h1 class="text-[22px] font-semibold text-gray-900 dark:text-white tracking-tight">Pending enrollments</h1>
        <p class="text-sm text-gray-500 mt-0.5">Review and respond to student enrollment requests.</p>
    </div>
    @if (Model.Count > 0)
    {
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-primary/10 text-primary text-sm font-semibold rounded-full">
            @Model.Count pending
        </span>
    }
</div>

@if (Model.Count == 0)
{
    @*Empty state*@
    <div class="flex flex-col items-center justify-center gap-3 py-20 border border-dashed border-gray-200 dark:border-gray-700 rounded-2xl text-center">
        <div class="w-12 h-12 flex items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800">
            <i data-lucide="inbox" class="w-6 h-6 text-gray-400"></i>
        </div>
        <div>
            <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-200">No pending requests</h2>
            <p class="text-sm text-gray-400 mt-0.5">Enrollment requests will appear here when students apply.</p>
        </div>
    </div>
}
else
{
    <div class="flex flex-col gap-3">
        @foreach (var item in Model)
        {
            <article class="bg-white dark:bg-gray-800/60 border border-gray-200 dark:border-gray-700 rounded-2xl overflow-hidden">
                <div class="flex items-start gap-4 p-5">

                    @* Avatar *@
                    <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                        <span class="text-sm font-semibold text-primary">
                            @item.Student.FullName.Split(' ').FirstOrDefault()?[0]@item.Student.FullName.Split(' ').Skip(1).FirstOrDefault()?[0]
                        </span>
                    </div>

                    @* Info *@
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 flex-wrap mb-0.5">
                            <span class="text-sm font-semibold text-gray-900 dark:text-white">@item.Student.FullName</span>
                            <span class="text-[11px] font-semibold tracking-widest uppercase px-2 py-0.5 rounded-md bg-primary/10 text-primary">
                                @item.Course.Code
                            </span>
                        </div>
                        <p class="text-xs text-gray-500 truncate">@item.Student.Email</p>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1.5">
                            Requested to enroll in
                            <span class="font-medium text-gray-800 dark:text-gray-200">@item.Course.Title</span>
                        </p>
                        <p class="text-xs text-gray-400 mt-0.5">
                            <i data-lucide="clock" class="w-3 h-3 inline-block mr-0.5 -mt-0.5"></i>
                            @item.RequestedAt.ToLocalTime().ToString("MMM d, h:mm tt")
                        </p>
                    </div>
                </div>

                @* Action bar *@
                <form asp-action="Decide" method="post"
                      class="flex items-center gap-2 px-5 py-3 bg-gray-50 dark:bg-gray-900/40 border-t border-gray-100 dark:border-gray-700 flex-wrap">
                    <input type="hidden" name="id" value="@item.Id" />
                    <input name="note" placeholder="Optional note to student…"
                           class="flex-1 min-w-[180px] px-3 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all" />
                    <button name="status" value="@EnrollmentStatus.Approved" type="submit"
                            class="inline-flex items-center gap-1.5 px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:opacity-90 transition-opacity">
                        <i data-lucide="check" class="w-4 h-4"></i>
                        Approve
                    </button>
                    <button name="status" value="@EnrollmentStatus.Rejected" type="submit"
                            class="inline-flex items-center gap-1.5 px-4 py-2 bg-transparent border border-red-200 dark:border-red-900 text-red-600 dark:text-red-400 rounded-lg text-sm font-medium hover:bg-red-50 dark:hover:bg-red-950 transition-colors">
                        <i data-lucide="x" class="w-4 h-4"></i>
                        Reject
                    </button>
                </form>
            </article>
        }
    </div>
}