@model AssignmentDetailsViewModel
@{
    ViewData["Title"] = Model.Assignment.Title;
    ViewData["PageTitle"] = "Assignment";
}

<section class="course-hero" style="--accent:#d97706">
    <div>
        <span class="badge"><i data-lucide="clipboard-check"></i>@Model.Assignment.Course.Code</span>
        <h2>@Model.Assignment.Title</h2>
        <p>@Model.Assignment.Brief</p>
        <div class="course-meta">
            <span>@Model.Assignment.MaxPoints points</span>
            <span>Due @Model.Assignment.DueAt.ToLocalTime().ToString("MMM d, yyyy")</span>
        </div>
    </div>
</section>

<section class="content-grid">
    <div>
        @if (Model.CanSubmit)
        {
            <form class="editor-panel" asp-action="Submit" method="post" enctype="multipart/form-data">
                <input type="hidden" name="AssignmentId" value="@Model.Assignment.Id" />
                <div class="form-heading">
                    <span class="badge"><i data-lucide="upload"></i> Student submission</span>
                    <h2>@(Model.MySubmission is null ? "Submit work" : "Update submission")</h2>
                </div>
                <label>File URL</label>
                <input name="FileUrl" value="@Model.MySubmission?.FileUrl" placeholder="GitHub, Drive, or hosted file link" />
                <label>Upload file</label>
                <input name="SubmissionFile" type="file" accept=".pdf,.zip,.docx,.png,.jpg,.jpeg" />
                <label>Notes</label>
                <textarea name="Notes" rows="5">@Model.MySubmission?.Notes</textarea>
                <button class="button" type="submit"><i data-lucide="send"></i>Submit assignment</button>
            </form>
        }

        @if (Model.MySubmission is not null)
        {
            <article class="submission-summary">
                <span class="badge"><i data-lucide="file-check"></i>Your submission</span>
                <p>Submitted @Model.MySubmission.SubmittedAt.ToLocalTime().ToString("MMM d, h:mm tt")</p>
                @if (!string.IsNullOrWhiteSpace(Model.MySubmission.FileUrl))
                {
                    <a class="button button-ghost button-small" href="@Model.MySubmission.FileUrl" target="_blank">Open file</a>
                }
                <p>@Model.MySubmission.Notes</p>
                @if (Model.MySubmission.Score is not null)
                {
                    <strong>@Model.MySubmission.Score / @Model.Assignment.MaxPoints</strong>
                    <p>@Model.MySubmission.Feedback</p>
                }
            </article>
        }
    </div>

    @if (Model.CanGrade)
    {
        <aside class="activity-panel">
            <div class="section-heading">
                <h2>Submissions</h2>
            </div>
            @foreach (var submission in Model.Submissions)
            {
                <div class="activity-item grade-item">
                    <span>@submission.SubmittedAt.ToLocalTime().ToString("MMM d, h:mm tt")</span>
                    <strong>@submission.Student.FullName</strong>
                    @if (!string.IsNullOrWhiteSpace(submission.FileUrl))
                    {
                        <a href="@submission.FileUrl" target="_blank">Open work</a>
                    }
                    <form asp-action="Grade" method="post">
                        <input type="hidden" name="SubmissionId" value="@submission.Id" />
                        <label>Score</label>
                        <input name="Score" type="number" min="0" max="@Model.Assignment.MaxPoints" step="0.5" value="@(submission.Score ?? 0)" />
                        <label>Feedback</label>
                        <textarea name="Feedback" rows="3">@submission.Feedback</textarea>
                        <button class="button button-small" type="submit">Grade</button>
                    </form>
                </div>
            }
        </aside>
    }
</section>
