@model IReadOnlyCollection<CourseCardViewModel>
@{
    ViewData["Title"] = "Saved Courses";
    ViewData["PageTitle"] = "Saved Courses";
}

<div class="mb-8 flex flex-col gap-4 rounded-2xl border border-slate-100 bg-white px-6 py-5 shadow-sm dark:border-gray-800 dark:bg-gray-900 sm:flex-row sm:items-center sm:justify-between">
    <div>
        <p class="text-[11px] font-semibold uppercase tracking-widest text-slate-400">Bookmarks</p>
        <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100">Saved Courses</h1>
    </div>
    <a asp-controller="Courses" asp-action="Index" class="inline-flex items-center justify-center gap-2 rounded-xl border border-slate-200 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">
        Browse courses
    </a>
</div>

@if (!Model.Any())
{
    <div class="rounded-2xl border border-dashed border-slate-300 bg-white p-10 text-center dark:border-slate-700 dark:bg-gray-900">
        <i data-lucide="bookmark" class="mx-auto h-12 w-12 text-slate-300"></i>
        <h2 class="mt-4 text-xl font-bold text-slate-900 dark:text-white">No saved courses yet</h2>
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Bookmark courses from the catalog to keep them here.</p>
    </div>
}
else
{
    <section class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        @foreach (var course in Model)
        {
            <div class="flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-100 dark:bg-gray-800 dark:ring-slate-800">
                <a asp-controller="Courses" asp-action="Details" asp-route-id="@course.Id" class="block">
                    <div class="relative h-44 w-full overflow-hidden" style="background-color:@(course.AccentColor + "22");">
                        @if (!string.IsNullOrWhiteSpace(course.CoverImageUrl))
                        {
                            <img src="@course.CoverImageUrl" alt="@course.Title" class="h-full w-full object-cover" />
                        }
                    </div>
                </a>
                <div class="flex flex-1 flex-col gap-3 p-5">
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-wide text-primary">@course.Code</p>
                            <h2 class="mt-1 font-bold text-slate-900 dark:text-white">@course.Title</h2>
                        </div>
                        <span class="shrink-0 text-sm font-black text-primary">@course.PriceLabel</span>
                    </div>
                    <p class="line-clamp-2 text-sm text-slate-500 dark:text-slate-400">@course.Summary</p>
                    <div class="mt-auto flex gap-2 pt-2">
                        <form asp-controller="SavedCourses" asp-action="Toggle" method="post" class="flex-1">
                            <input type="hidden" name="courseId" value="@course.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <button type="submit" class="flex w-full items-center justify-center gap-2 rounded-xl border border-slate-200 px-3 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">
                                <i data-lucide="bookmark-x" class="h-4 w-4"></i>
                                Remove
                            </button>
                        </form>
                        @if (course.EnrollmentStatus != EnrollmentStatus.Approved)
                        {
                            <form asp-controller="Cart" asp-action="Add" method="post" class="flex-1">
                                <input type="hidden" name="courseId" value="@course.Id" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <button type="submit" class="flex w-full items-center justify-center gap-2 rounded-xl bg-primary px-3 py-2.5 text-sm font-bold text-white transition hover:brightness-110">
                                    <i data-lucide="shopping-cart" class="h-4 w-4"></i>
                                    @(course.IsInCart ? "In cart" : "Add")
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </section>
}
