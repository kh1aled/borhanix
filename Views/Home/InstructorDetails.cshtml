@model InstructorProfileViewModel
@{
    ViewData["Title"] = Model.FullName;
    ViewData["PageTitle"] = "Instructors";
    Layout = "_LandingLayout";

    string Initials(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "?";
        var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][0].ToString().ToUpper(),
            _ => (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper()
        };
    }
}

<section class="px-[80px] pt-32 pb-16">

    @* Breadcrumb / back link *@
    <div class="mb-6 px-6">
        <a asp-controller="Home"
           asp-action="Instructors"
           class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 transition hover:text-primary dark:text-slate-400">
            <i data-lucide="arrow-left" class="h-4 w-4"></i>
            Back to Instructors
        </a>
    </div>

    <div class="mx-auto max-w-4xl px-6">
        <div class="overflow-hidden rounded-[32px] bg-white shadow-sm dark:bg-slate-900">

            @* Cover banner tinted with the instructor's accent color *@
            <div class="relative h-36 w-full sm:h-44" style="background-color:@(Model.AvatarColor)22;">
                <div class="pointer-events-none absolute inset-0 opacity-40">
                    <span class="absolute top-8 right-16 h-10 w-10 rotate-12 rounded-lg border-2 border-current" style="color:@Model.AvatarColor;"></span>
                    <span class="absolute top-16 right-40 h-3 w-3 rounded-full" style="background-color:@Model.AvatarColor;"></span>
                    <span class="absolute bottom-6 left-12 h-8 w-8 rotate-45 rounded-md border-2 border-current" style="color:@Model.AvatarColor;"></span>
                    <span class="absolute bottom-10 left-32 h-2 w-2 rounded-full" style="background-color:@Model.AvatarColor;"></span>
                </div>

                @if (Model.IsApproved)
                {
                    <span class="absolute top-4 right-5 inline-flex items-center gap-1.5 rounded-full bg-white/90 px-3 py-1.5 text-xs font-semibold text-emerald-600 shadow dark:bg-slate-900/90">
                        <i data-lucide="badge-check" class="h-4 w-4"></i>
                        Verified Instructor
                    </span>
                }
            </div>

            <div class="px-6 pb-10 sm:px-10">

                @* Avatar + identity — overlapping the banner *@
                <div class="-mt-14 flex flex-col items-center text-center sm:-mt-16">
                    @if (!string.IsNullOrWhiteSpace(Model.ProfilePhotoUrl))
                    {
                        <img src="@Model.ProfilePhotoUrl"
                             alt="@Model.FullName"
                             class="h-28 w-28 rounded-full border-4 border-white object-cover shadow-md sm:h-32 sm:w-32 dark:border-slate-900" />
                    }
                    else
                    {
                        <div class="flex h-28 w-28 items-center justify-center rounded-full border-4 border-white text-2xl font-bold text-white shadow-md sm:h-32 sm:w-32 dark:border-slate-900"
                             style="background-color:@Model.AvatarColor;">
                            @Initials(Model.FullName)
                        </div>
                    }

                    <h1 class="mt-5 text-2xl font-extrabold text-slate-900 sm:text-3xl dark:text-white">
                        @Model.FullName
                    </h1>

                    @if (!string.IsNullOrWhiteSpace(Model.LevelOrTitle))
                    {
                        <p class="mt-1 text-base font-medium text-primary">@Model.LevelOrTitle</p>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.Department))
                    {
                        <span class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-3.5 py-1.5 text-xs font-semibold text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                            <i data-lucide="building-2" class="h-3.5 w-3.5"></i>
                            @Model.Department
                        </span>
                    }
                </div>

                @* Info row: office hours *@
                @if (!string.IsNullOrWhiteSpace(Model.OfficeHours))
                {
                    <div class="mx-auto mt-8 flex max-w-md items-center justify-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4 dark:border-slate-700 dark:bg-slate-800/60">
                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10">
                            <i data-lucide="clock" class="h-5 w-5 text-primary"></i>
                        </div>
                        <div class="text-left">
                            <p class="text-xs font-semibold tracking-wide text-slate-400 uppercase dark:text-slate-500">Office Hours</p>
                            <p class="text-sm font-semibold text-slate-700 dark:text-slate-200">@Model.OfficeHours</p>
                        </div>
                    </div>
                }

                @* About / bio *@
                <div class="mx-auto mt-10 max-w-2xl">
                    <h2 class="mb-3 flex items-center gap-2 text-lg font-bold text-slate-800 dark:text-white">
                        <i data-lucide="user-round" class="h-5 w-5 text-primary"></i>
                        About
                    </h2>

                    @if (!string.IsNullOrWhiteSpace(Model.Bio))
                    {
                        <p class="text-[15px] leading-7 whitespace-pre-line text-slate-600 dark:text-slate-400">
                            @Model.Bio
                        </p>
                    }
                    else
                    {
                        <div class="flex items-center gap-3 rounded-2xl border border-dashed border-slate-200 px-5 py-6 text-sm text-slate-400 dark:border-slate-700 dark:text-slate-500">
                            <i data-lucide="info" class="h-4 w-4"></i>
                            This instructor hasn't added a bio yet.
                        </div>
                    }
                </div>

                @* Courses by this instructor — placeholder CTA *@
                <div class="mx-auto mt-10 max-w-2xl border-t border-slate-100 pt-8 text-center dark:border-slate-800">
                    <a asp-controller="Home"
                       asp-action="Courses"
                       class="inline-flex items-center gap-2 rounded-xl bg-primary px-6 py-3 font-semibold text-white transition hover:-translate-y-0.5 hover:shadow-lg">
                        <i data-lucide="book-open" class="h-5 w-5"></i>
                        View Courses
                    </a>
                </div>

            </div>
        </div>
    </div>

</section>
