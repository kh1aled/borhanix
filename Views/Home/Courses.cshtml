@model IReadOnlyCollection<CourseCardViewModel>
@{
    ViewData["Title"] = "Courses";
    ViewData["PageTitle"] = "Course Catalog";
    Layout = "_LandingLayout";
    var selectedLevel = Context.Request.Query["level"].ToString();
    var isFiltered = !string.IsNullOrWhiteSpace(selectedLevel);
}

<section class="px-[80px] pt-32 pb-8">
    @* Toolbar: filters + view toggle + count + New Course action *@
    <div class="mb-8 flex flex-col gap-4 px-6 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-center gap-4">
            <p class="text-lg font-semibold text-slate-800 dark:text-slate-100">
                Offering <span class="font-bold text-primary">@Model.Count</span> Courses
            </p>

            @if (User.IsInRole(AppRoles.Instructor) || User.IsInRole(AppRoles.Admin))
            {
                <a class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-white shadow shadow-primary/20 transition hover:-translate-y-0.5 hover:brightness-110 active:scale-95"
                   asp-controller="InstructorStudio" asp-action="CreateCourse">
                    <i data-lucide="plus" class="h-4 w-4"></i>
                    New Course
                </a>
            }
        </div>
        <div class="flex flex-wrap items-center gap-3">
            @* NOTE: visual only for now — wire these up once category/level filtering exists *@
            <form asp-controller="Home"
                  asp-action="Courses"
                  method="get"
                  class="relative flex-1">
                  
                <input type="text"
                       name="search"
                       value="@Context.Request.Query["search"]"
                       placeholder="Search courses..."
                       class="w-full rounded-2xl border border-slate-200 bg-white py-3 pr-24 pl-12 text-sm text-slate-700 shadow-sm transition outline-none
                placeholder:text-slate-400
                focus:border-primary focus:ring-4 focus:ring-primary/10
                dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:placeholder:text-slate-500" />

                <button type="submit"
                        class="absolute top-1/2 right-2 -translate-y-1/2 rounded-full bg-primary p-2 font-semibold text-white transition hover:brightness-110 active:scale-95">
                    <i data-lucide="search" class="h-4 w-4"></i>
                </button>

            </form>
            <form id="level-form" asp-controller="Home" asp-action="Courses" method="get" class="flex gap-3">

                <select onchange="this.form.submit()"
                        name="level"
                        class="rounded-xl border border-slate-300 px-4 py-2 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200">

                    <option value="" selected="@(!isFiltered)">All Levels</option>
                    <option value="Beginner" selected="@(selectedLevel == "Beginner")">Beginner</option>
                    <option value="Intermediate" selected="@(selectedLevel == "Intermediate")">Intermediate</option>
                    <option value="Advanced" selected="@(selectedLevel == "Advanced")">Advanced</option>

                </select>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="flex min-h-[420px] items-center justify-center px-6">
            <div class="w-full max-w-2xl rounded-3xl border border-slate-200 bg-white p-12 text-center shadow-sm dark:border-slate-700 dark:bg-slate-900">

                <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-primary/10">
                    <i data-lucide="@(isFiltered ? "filter-x" : "book-open")" class="h-10 w-10 text-primary"></i>
                </div>

                <h2 class="mt-6 text-3xl font-bold text-slate-900 dark:text-white">
                    @(isFiltered ? "No Courses Match This Filter" : "No Courses Yet")
                </h2>

                <p class="mx-auto mt-3 max-w-lg text-base leading-7 text-slate-500 dark:text-slate-400">
                    @if (isFiltered)
                    {
                        <text>We couldn't find any <strong>@selectedLevel</strong> level courses right now. Try another level or browse everything we offer.</text>
                    }
                    else
                    {
                        <text>There aren't any courses published yet. Check back soon, or if you're an instructor, be the first to create one.</text>
                    }
                </p>

                <div class="mt-8 flex flex-wrap justify-center gap-4">

                    @if (isFiltered)
                    {
                        <a asp-controller="Home"
                           asp-action="Courses"
                           class="inline-flex items-center gap-2 rounded-xl bg-primary px-6 py-3 font-semibold text-white transition hover:-translate-y-0.5 hover:shadow-lg">

                            <i data-lucide="grid-2x2" class="h-5 w-5"></i>
                            Browse All Courses
                        </a>

                        <button onclick="history.back()"
                                class="inline-flex items-center gap-2 rounded-xl border border-slate-300 px-6 py-3 font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-600 dark:text-slate-200 dark:hover:bg-slate-800">

                            <i data-lucide="arrow-left" class="h-5 w-5"></i>
                            Go Back
                        </button>
                    }
                    else if (User.IsInRole(AppRoles.Instructor) || User.IsInRole(AppRoles.Admin))
                    {
                        <a asp-controller="InstructorStudio"
                           asp-action="CreateCourse"
                           class="inline-flex items-center gap-2 rounded-xl bg-primary px-6 py-3 font-semibold text-white transition hover:-translate-y-0.5 hover:shadow-lg">

                            <i data-lucide="plus" class="h-5 w-5"></i>
                            Create the First Course
                        </a>
                    }

                </div>

            </div>
        </div>
    }
    else
    {
        <div class="grid gap-6 px-6 sm:grid-cols-2 lg:grid-cols-3">
            @foreach (var course in Model)
            {
                <div class="group flex flex-col overflow-hidden rounded-[28px] bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl dark:bg-slate-900">

                    @* Hero area *@
                    <div class="relative h-52 w-full overflow-hidden"
                         style="background-color: @(string.IsNullOrWhiteSpace(course.HeroImageUrl) ? (course.AccentColor + "22") : "transparent");">

                        @if (string.IsNullOrWhiteSpace(course.HeroImageUrl))
                        {
                            @* Decorative shapes to fill the illustrated background, purely cosmetic *@
                            <div class="pointer-events-none absolute inset-0 opacity-40">
                                <span class="absolute top-6 right-10 h-8 w-8 rotate-12 rounded border-2 border-current" style="color:@course.AccentColor;"></span>
                                <span class="absolute top-20 right-24 h-3 w-3 rounded-full" style="background-color:@course.AccentColor;"></span>
                                <span class="absolute bottom-8 left-8 h-10 w-10 rotate-45 rounded-md border-2 border-current" style="color:@course.AccentColor;"></span>
                                <span class="absolute top-10 left-24 h-2 w-2 rounded-full" style="background-color:@course.AccentColor;"></span>
                            </div>

                            <div class="relative flex h-full flex-col items-start justify-center px-6">
                                <h3 class="text-3xl leading-tight font-extrabold tracking-tight text-slate-800 dark:text-slate-100">
                                    @course.Title
                                </h3>
                                <div class="mt-2 h-1 w-10 rounded-full" style="background-color:@course.AccentColor;"></div>
                            </div>
                        }
                        else
                        {
                            <img src="@course.HeroImageUrl"
                                 alt="@course.Title"
                                 class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
                        }

                        @* Level badge — top-left pill *@
                        <span class="absolute top-3 left-5 rounded-full px-3 py-1 font-bold tracking-wide text-[11px] text-white uppercase shadow"
                              style="background-color:@course.AccentColor;">
                            @course.Level
                        </span>
                    </div>

                    @* Card body *@
                    <div class="flex flex-1 flex-col gap-4 p-5">

                        @* Code + Category chips *@
                        <div class="flex flex-wrap gap-1.5">
                            <span class="rounded-full bg-slate-100 px-2.5 py-0.5 font-semibold text-[11px] text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                                @course.Code
                            </span>
                            <span class="rounded-full bg-slate-100 px-2.5 py-0.5 font-semibold text-[11px] text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                                @course.Category
                            </span>
                            <span class="ms-auto text-sm font-black text-primary">@course.PriceLabel</span>
                        </div>

                        @* Title + summary *@
                        <div class="space-y-1.5">
                            <h2 class="leading-snug font-bold text-[17px] text-slate-800 dark:text-white">
                                @course.Title
                            </h2>
                            <p class="line-clamp-2 text-sm leading-relaxed text-slate-500 dark:text-slate-400">
                                @course.Summary
                            </p>
                        </div>

                        @* Stats row *@
                        <div class="flex items-center gap-4 text-sm text-slate-500 dark:text-slate-400">
                            <span class="flex items-center gap-1.5">
                                <i data-lucide="layout-list" class="h-4 w-4"></i>
                                <span>@course.ModuleCount lesson</span>
                            </span>
                            <span class="flex items-center gap-1.5">
                                <i data-lucide="users" class="h-4 w-4"></i>
                                <span>@course.EnrollmentCount student</span>
                            </span>
                        </div>

                        @* Enrollment status badge (optional) *@
                        @if (course.EnrollmentStatus is not null)
                        {
                            <div>
                                <span class="inline-flex items-center gap-1 rounded-full border border-slate-200 bg-slate-50 px-3 py-1 font-semibold tracking-wide text-[11px] text-slate-600 uppercase dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300">
                                    <i data-lucide="check-circle-2" class="h-3 w-3"></i>
                                    @course.EnrollmentStatus
                                </span>
                            </div>
                        }

                        @* CTA — pushed to bottom *@
                        <div class="mt-auto pt-2">
                            <a asp-controller="Courses" asp-route-id="@course.Id" asp-action="Details"
                               class="flex w-full items-center justify-center gap-2 rounded-xl bg-slate-100 px-4 py-3 text-sm font-semibold text-slate-700 transition group-hover:bg-slate-200 dark:bg-slate-800 dark:text-slate-200 dark:group-hover:bg-slate-700">
                                Show More Details
                                <i data-lucide="arrow-right" class="h-4 w-4 transition duration-300 group-hover:translate-x-1"></i>
                            </a>
                            @if (User.IsInRole(AppRoles.Student) && course.EnrollmentStatus != EnrollmentStatus.Approved)
                            {
                                <div class="mt-2 grid grid-cols-2 gap-2">
                                    <form asp-controller="Cart" asp-action="Add" method="post">
                                        <input type="hidden" name="courseId" value="@course.Id" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" class="flex w-full items-center justify-center gap-1 rounded-xl bg-primary px-3 py-2.5 text-xs font-bold text-white transition hover:brightness-110">
                                            <i data-lucide="shopping-cart" class="h-4 w-4"></i>
                                            @(course.IsInCart ? "In Cart" : "Add")
                                        </button>
                                    </form>
                                    <form asp-controller="SavedCourses" asp-action="Toggle" method="post">
                                        <input type="hidden" name="courseId" value="@course.Id" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" class="flex w-full items-center justify-center gap-1 rounded-xl border border-slate-200 px-3 py-2.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">
                                            <i data-lucide="bookmark" class="h-4 w-4"></i>
                                            @(course.IsSaved ? "Saved" : "Save")
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</section>
