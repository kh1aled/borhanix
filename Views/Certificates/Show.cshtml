@model CertificateViewModel
@{
    ViewData["Title"] = "Certificate";
    Layout = null;
    var issuedDate = Model.Certificate.IssuedAt.ToLocalTime().ToString("MMMM d, yyyy");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Certificate — @Model.CourseTitle</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Playfair+Display:ital@1&display=swap" rel="stylesheet">
    <style>
            :root {
                --brand-primary: #0ea5e9;
                --brand-primary-dark: #0369a1;
                --brand-accent: #22c55e;
                --brand-ink: #0f172a;
                --brand-muted: #64748b;
            }

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                background: #eef2f6;
                font-family: "Poppins", system-ui, sans-serif;
                color: var(--brand-ink);
                padding: 2rem;
            }

            .certificate {
                width: min(1000px, 100%);
                aspect-ratio: 1.42 / 1;
                background: #fff;
                position: relative;
                box-shadow: 0 25px 70px rgba(15, 23, 42, 0.15);
                border: 3px solid var(--brand-primary);
                padding: 2.75rem 3.5rem;
                display: flex;
                flex-direction: column;
            }

                /* faint background watermark wave, echoes the reference cert's texture */
                .certificate::before {
                    content: "";
                    position: absolute;
                    inset: 0;
                    background: radial-gradient(ellipse at 15% 15%, rgba(14, 165, 233, 0.06), transparent 55%), radial-gradient(ellipse at 85% 85%, rgba(34, 197, 94, 0.05), transparent 55%);
                    pointer-events: none;
                }

            /* ── Hollow diamond corner ornaments ───────────────────────────── */
            .corner-diamond {
                position: absolute;
                width: 34px;
                height: 34px;
                border: 2.5px solid var(--brand-primary);
                transform: rotate(45deg);
            }

                .corner-diamond.tl {
                    top: 18px;
                    left: 18px;
                }

                .corner-diamond.tr {
                    top: 18px;
                    right: 18px;
                }

                .corner-diamond.bl {
                    bottom: 18px;
                    left: 18px;
                }

                .corner-diamond.br {
                    bottom: 18px;
                    right: 18px;
                }

            /* small filled dots that sit beside the corner diamonds, like the reference */
            .corner-dot {
                position: absolute;
                width: 8px;
                height: 8px;
                background: var(--brand-accent);
                transform: rotate(45deg);
            }

                .corner-dot.tl {
                    top: 30px;
                    left: 62px;
                }

                .corner-dot.tr {
                    top: 30px;
                    right: 62px;
                }

                .corner-dot.bl {
                    bottom: 30px;
                    left: 62px;
                }

                .corner-dot.br {
                    bottom: 30px;
                    right: 62px;
                }

            /* ── Header ─────────────────────────────────────────────────────── */
            .cert-inner {
                position: relative;
                z-index: 1;
                display: flex;
                flex-direction: column;
                height: 100%;
            }

            .cert-logo-row {
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 0.5rem;
            }

                .cert-logo-row img {
                    height: 46px;
                    width: auto;
                    object-fit: contain;
                }

            .diamond-divider {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
                margin: 1rem 0 0.25rem;
            }

                .diamond-divider .line {
                    height: 1px;
                    width: 90px;
                    background: linear-gradient(90deg, transparent, #cbd5e1);
                }

                    .diamond-divider .line.right {
                        background: linear-gradient(270deg, transparent, #cbd5e1);
                    }

                .diamond-divider span {
                    width: 9px;
                    height: 9px;
                    background: var(--brand-accent);
                    transform: rotate(45deg);
                }

                    .diamond-divider span:nth-child(3) {
                        width: 13px;
                        height: 13px;
                    }

            .cert-title {
                text-align: center;
                margin-top: 0.75rem;
            }

                .cert-title h1 {
                    margin: 0;
                    font-size: 3.1rem;
                    font-weight: 800;
                    letter-spacing: 0.06em;
                    color: var(--brand-primary);
                    line-height: 1;
                }

                .cert-title h2 {
                    margin: 0.4rem 0 0;
                    font-size: 1.15rem;
                    font-weight: 500;
                    letter-spacing: 0.55em;
                    color: var(--brand-ink);
                    padding-left: 0.55em; /* optically re-center the extra letter-spacing */
                }

            .cert-stars {
                text-align: center;
                margin: 0.85rem 0;
                color: var(--brand-primary);
                font-size: 0.9rem;
                letter-spacing: 0.4em;
            }

            .cert-certifies {
                text-align: center;
                font-size: 0.95rem;
                font-weight: 600;
                color: var(--brand-ink);
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 0.75rem;
            }

                .cert-certifies .arrow {
                    color: var(--brand-primary);
                }

            /* ── Body ───────────────────────────────────────────────────────── */
            .cert-body {
                flex: 1;
                text-align: center;
                display: flex;
                flex-direction: column;
                justify-content: center;
                gap: 0.5rem;
            }

            .cert-name {
                font-family: "Playfair Display", Georgia, serif;
                font-style: italic;
                font-size: 2.5rem;
                font-weight: 700;
                color: var(--brand-ink);
                margin: 0.5rem 0 0.75rem;
            }

            .cert-underline {
                width: 420px;
                max-width: 80%;
                height: 1px;
                background: var(--brand-primary);
                margin: 0 auto 1rem;
            }

            .cert-description {
                font-size: 1.05rem;
                line-height: 1.7;
                color: #334155;
                max-width: 640px;
                margin: 0 auto;
            }

                .cert-description strong {
                    color: var(--brand-primary-dark);
                }

            .cert-message {
                margin: 1.1rem auto 0;
                max-width: 620px;
                font-style: italic;
                color: var(--brand-muted);
                font-size: 0.95rem;
            }

            .cert-grade {
                margin-top: 0.9rem;
                font-size: 1rem;
            }

                .cert-grade strong {
                    color: var(--brand-primary-dark);
                    font-size: 1.1rem;
                }

            /* ── Footer ─────────────────────────────────────────────────────── */
            .cert-footer {
                display: flex;
                justify-content: space-between;
                align-items: flex-end;
                gap: 1.5rem;
            }

                .cert-footer .field {
                    text-align: left;
                    font-size: 0.85rem;
                    color: var(--brand-muted);
                }

                    .cert-footer .field.right {
                        text-align: right;
                    }

                    .cert-footer .field strong {
                        display: block;
                        color: var(--brand-ink);
                        font-size: 0.9rem;
                        margin-bottom: 2px;
                    }

            .cert-signature {
                text-align: center;
                flex-shrink: 0;
            }

                .cert-signature .scribble {
                    font-family: "Playfair Display", cursive;
                    font-style: italic;
                    font-size: 1.4rem;
                    color: var(--brand-primary-dark);
                    border-bottom: 1px solid var(--brand-muted);
                    padding: 0 0.5rem 0.35rem;
                    margin-bottom: 0.3rem;
                }

                .cert-signature .role {
                    font-size: 0.78rem;
                    color: var(--brand-muted);
                }

            .cert-brand-footer {
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 0.4rem;
                margin-top: 1.25rem;
                font-size: 0.8rem;
                color: var(--brand-muted);
            }

                .cert-brand-footer img {
                    height: 20px;
                    width: auto;
                }

            /* ── Print / back actions (hidden on print) ───────────────────────── */
            .cert-actions {
                margin-top: 1.5rem;
                text-align: center;
            }

                .cert-actions button, .cert-actions a {
                    display: inline-block;
                    margin: 0 0.5rem;
                    padding: 0.65rem 1.25rem;
                    border-radius: 8px;
                    text-decoration: none;
                    font-family: "Poppins", system-ui, sans-serif;
                    font-size: 0.9rem;
                    font-weight: 600;
                    cursor: pointer;
                    border: none;
                }

            .btn-print {
                background: var(--brand-primary);
                color: #fff;
            }

            .btn-back {
                background: #e2e8f0;
                color: var(--brand-ink);
            }

            @@media print {
                body {
                    background: #fff;
                    padding: 0;
                }

                .cert-actions {
                    display: none;
                }

                .certificate {
                    box-shadow: none;
                    width: 100%;
                    aspect-ratio: auto;
                }
            }
    </style>
</head>
<body>
    <div>
        <div class="certificate">
            <div class="corner-diamond tl"></div>
            <div class="corner-diamond tr"></div>
            <div class="corner-diamond bl"></div>
            <div class="corner-diamond br"></div>
            <div class="corner-dot tl"></div>
            <div class="corner-dot tr"></div>
            <div class="corner-dot bl"></div>
            <div class="corner-dot br"></div>

            <div class="cert-inner">
                <div class="cert-logo-row">
                    <img src="~/images/borhanix-logo.png" alt="Borhanix logo" />
                </div>

                <div class="diamond-divider">
                    <span></span><span></span><span></span><span></span><span></span>
                </div>

                <div class="cert-title">
                    <h1>CERTIFICATE</h1>
                    <h2>OF COMPLETION</h2>
                </div>

                <div class="cert-certifies">
                    <span class="arrow">&#8722;&#8722;&#8722;</span>
                    <span>Borhanix Certifies That</span>
                    <span class="arrow">&#8722;&#8722;&#8722;</span>
                </div>

                <div class="cert-body">
                    <div class="cert-name">@Model.StudentFullName</div>
                    <div class="cert-underline"></div>

                    <p class="cert-description">
                        Has successfully completed the course
                        <strong>@Model.CourseTitle</strong> (@Model.CourseCode)
                        on the Borhanix Learning Management Platform.
                    </p>


                        <div class="cert-message"></div>


                    <div class="cert-grade">
                        Final grade: <strong>@Model.Certificate.FinalGradePercent.ToString("F1")%</strong>
                    </div>
                </div>

                <div class="cert-footer">
                    <div class="field">
                        <strong>Date of completion</strong>
                        @issuedDate
                    </div>

                    <div class="cert-signature">
                        <div class="scribble">Borhanix</div>
                        <div class="role">Learning Platform</div>
                    </div>

                    <div class="field right">
                        <strong>Certificate no.</strong>
                        @Model.Certificate.CertificateNumber
                    </div>
                </div>
            </div>
        </div>

        <div class="cert-actions">
            <button class="btn-print" type="button" onclick="document.querySelector(".certificate").print()">Print certificate</button>
            <a class="btn-back" asp-controller="Courses" asp-action="Details" asp-route-id="@Model.Certificate.CourseId">Back to course</a>
        </div>
    </div>
</body>
</html>
