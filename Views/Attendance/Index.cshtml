@model AttendanceIndexViewModel
@{
    ViewData["Title"] = "Attendance";
    ViewData["PageTitle"] = "QR attendance";
}

@if (User.IsInRole(AppRoles.Student))
{
    @*Student view *@
    <div class="mx-auto space-y-6">

        @* Header *@
        <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 flex items-start justify-between gap-4 flex-wrap">
            <div>
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-medium mb-2">
                    <i data-lucide="id-card" class="w-3.5 h-3.5"></i>
                    Student attendance
                </div>
                <h1 class="text-2xl font-semibold text-gray-900 dark:text-white">Your records</h1>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">All your attendance history across courses</p>
            </div>
            <a asp-action="StudentCard"
               class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-gray-900 dark:bg-white text-white dark:text-gray-900 text-sm font-medium hover:bg-gray-700 dark:hover:bg-gray-100 transition-colors">
                <i data-lucide="qr-code" class="w-4 h-4"></i>
                My ID card
            </a>
        </div>

        @* Table card *@
        <div class="bg-white overflow-x-auto dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-100 dark:border-gray-800">
                        <th class="text-left text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider px-6 py-4">Course</th>
                        <th class="text-left text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider px-6 py-4">Session</th>
                        <th class="text-left text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider px-6 py-4">Status</th>
                        <th class="text-left text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider px-6 py-4">Captured</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 dark:divide-gray-800/60">
                    @foreach (var record in Model.Records)
                    {
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/40 transition-colors">
                            <td class="px-6 py-4 font-mono text-xs font-semibold text-gray-700 dark:text-gray-200">
                                @record.AttendanceSession.Course.Code
                            </td>
                            <td class="px-6 py-4 text-gray-700 dark:text-gray-300">
                                @record.AttendanceSession.Title
                            </td>
                            <td class="px-6 py-4">
                                @{
                                    var status = record.Status.ToString();
                                    var pillClass = status switch
                                    {
                                        "Present" => "bg-emerald-50 text-emerald-700 border border-emerald-200 dark:bg-emerald-900/30 dark:text-emerald-400 dark:border-emerald-800",
                                        "Late" => "bg-amber-50 text-amber-700 border border-amber-200 dark:bg-amber-900/30 dark:text-amber-400 dark:border-amber-800",
                                        "Absent" => "bg-red-50 text-red-700 border border-red-200 dark:bg-red-900/30 dark:text-red-400 dark:border-red-800",
                                        _ => "bg-gray-100 text-gray-600 border border-gray-200 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-700"
                                    };
                                }
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium @pillClass">
                                    @record.Status
                                </span>
                            </td>
                            <td class="px-6 py-4 text-gray-500 dark:text-gray-400 tabular-nums">
                                @record.CapturedAt.ToLocalTime().ToString("MMM d, h:mm tt")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Records.Any())
            {
                <div class="flex flex-col items-center justify-center py-16 text-center">
                    <div class="w-12 h-12 rounded-full bg-gray-100 dark:bg-gray-800 flex items-center justify-center mb-3">
                        <i data-lucide="calendar-x" class="w-5 h-5 text-gray-400"></i>
                    </div>
                    <p class="text-sm font-medium text-gray-600 dark:text-gray-300">No records yet</p>
                    <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Your attendance will appear here once sessions are captured.</p>
                </div>
            }
        </div>

    </div>
}
else
{
    @* Instructor view *@
    <div class="mx-auto space-y-8">

        @* Header *@
        <div class="flex items-start justify-between gap-4 flex-wrap">
            <div>
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-medium mb-2">
                    <i data-lucide="scan-line" class="w-3.5 h-3.5"></i>
                    Instructor attendance
                </div>
                <h1 class="text-2xl font-semibold text-gray-900 dark:text-white">Sessions</h1>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">Create and manage your QR attendance sessions</p>
            </div>
            <a asp-action="Scanner"
               class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-primary text-white text-sm font-medium hover:bg-primary/90 transition-colors">
                <i data-lucide="scan-qr-code" class="w-4 h-4"></i>
                Open scanner
            </a>
        </div>

        @* Create session panel *@
        <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6">
            <h2 class="text-base font-semibold text-gray-900 dark:text-white mb-5 flex items-center gap-2">
                <i data-lucide="calendar-plus" class="w-4 h-4 text-primary"></i>
                Create attendance session
            </h2>
            <form asp-action="CreateSession" method="post" class="space-y-5">
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                    <div class="flex flex-col gap-1.5">
                        <label asp-for="NewSession.CourseId" class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Course</label>
                        <select asp-for="NewSession.CourseId" name="CourseId"
                                class="w-full px-3 py-2.5 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors">
                            @foreach (var course in Model.Courses)
                            {
                                <option value="@course.Id">@course.Code – @course.Title</option>
                            }
                        </select>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label asp-for="NewSession.Title" class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Title</label>
                        <input asp-for="NewSession.Title" name="Title" placeholder="Lecture attendance"
                               class="w-full px-3 py-2.5 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm text-gray-900 dark:text-white placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors" />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label asp-for="NewSession.OpensAt" class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Opens</label>
                        <input asp-for="NewSession.OpensAt" name="OpensAt" type="datetime-local"
                               class="w-full px-3 py-2.5 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors" />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label asp-for="NewSession.ClosesAt" class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Closes</label>
                        <input asp-for="NewSession.ClosesAt" name="ClosesAt" type="datetime-local"
                               class="w-full px-3 py-2.5 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors" />
                    </div>
                </div>

                <div class="pt-1">
                    <button type="submit"
                            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-primary text-white text-sm font-medium hover:bg-primary/90 transition-colors">
                        <i data-lucide="calendar-plus" class="w-4 h-4"></i>
                        Create session
                    </button>
                </div>
            </form>
        </div>

        @* Sessions grid *@
        @if (Model.Sessions.Any())
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                @foreach (var session in Model.Sessions)
                {
                    <article class="group bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-5 hover:border-primary/40 hover:shadow-sm transition-all flex flex-col gap-4">
                        <div class="flex items-start justify-between gap-2">
                            <span class="inline-block px-2.5 py-1 rounded-lg bg-primary/10 text-primary text-xs font-mono font-semibold">
                                @session.Course.Code
                            </span>
                            <span class="text-xs text-gray-400 dark:text-gray-500 tabular-nums">
                                @session.SessionDate.ToLocalTime().ToString("MMM d, yyyy")
                            </span>
                        </div>

                        <div>
                            <h3 class="font-semibold text-gray-900 dark:text-white text-sm leading-snug">@session.Title</h3>
                        </div>

                        <div class="flex items-center justify-between text-xs text-gray-500 dark:text-gray-400 border-t border-gray-100 dark:border-gray-800 pt-3 mt-auto">
                            <div class="flex items-center gap-1.5">
                                <i data-lucide="users" class="w-3.5 h-3.5"></i>
                                <span>@session.Records.Count scans</span>
                            </div>
                            <span class="font-mono text-gray-400 dark:text-gray-500">@session.SessionCode</span>
                        </div>

                        <a asp-action="Scanner" asp-route-sessionId="@session.Id"
                           class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-xl border border-gray-200 dark:border-gray-700 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 hover:border-primary/40 hover:text-primary transition-colors">
                            <i data-lucide="scan-line" class="w-4 h-4"></i>
                            Scan students
                        </a>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="flex flex-col items-center justify-center py-20 text-center">
                <div class="w-14 h-14 rounded-2xl bg-gray-100 dark:bg-gray-800 flex items-center justify-center mb-4">
                    <i data-lucide="calendar-off" class="w-6 h-6 text-gray-400"></i>
                </div>
                <p class="text-sm font-semibold text-gray-700 dark:text-gray-200">No sessions yet</p>
                <p class="text-xs text-gray-400 dark:text-gray-500 mt-1 max-w-xs">Create your first session above and students can scan in using their ID card QR code.</p>
            </div>
        }

    </div>
}
